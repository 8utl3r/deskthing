              "value": "={{ $('Parse Input').item.json.timestamp }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "low-confidence-reasoning",
      "name": "Low Confidence Reasoning",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.3,
      "position": [1450, 400]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "final_decision",
              "name": "final_decision",
              "value": "={{ {\n  \"question\": $json.question,\n  \"decision\": $json.selected_option,\n  \"confidence\": $json.confidence_score,\n  \"reasoning\": $json.reasoning,\n  \"emoji\": $json.emoji,\n  \"factors\": {\n    \"random_seed\": $json.random_seed,\n    \"hour_of_day\": $json.hour_of_day,\n    \"question_length\": $json.question_length,\n    \"options_considered\": $json.options_count\n  },\n  \"external_influences\": {\n    \"inspirational_quote\": $('Fetch Random Quote').item.json.content ? ($('Fetch Random Quote').item.json.content + \" - \" + $('Fetch Random Quote').item.json.author) : \"The universe works in mysterious ways.\",\n    \"chuck_norris_wisdom\": $('Fetch Chuck Norris Joke').item.json.value || \"Chuck Norris doesn't need APIs.\",\n    \"age_data\": $('Fetch Age Data').item.json.age || \"unknown\"\n  },\n  \"timestamp\": $json.timestamp,\n  \"message\": $json.emoji + \" Decision: \" + $json.selected_option + \" (Confidence: \" + $json.confidence_score + \"%)\"\n} }}",
              "type": "object"
            }
          ]
        },
        "options": {}
      },
      "id": "package-decision",
      "name": "Package Decision",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.3,
      "position": [1650, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ $json.final_decision }}",
        "options": {}
