            {
              "id": "reasoning",
              "name": "reasoning",
              "value": "={{ [\n  \"I'm not entirely sure, but this feels right... maybe?\",\n  \"The data is inconclusive, so I'm going with my gut.\",\n  \"After much deliberation, I'm 60% sure this is correct.\",\n  \"The tea leaves were unclear, but this seems reasonable.\",\n  \"I asked my pet rock and it didn't object.\",\n  \"This decision is based on vibes and vibes alone.\"\n][Math.floor(Math.random() * 6)] }}",
              "type": "string"
