      "typeVersion": 1,
      "position": [850, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { \"success\": false, \"error\": \"Invalid operation. Must be 'create', 'update', or 'delete'.\" } }}",
        "options": {}
      },
      "id": "respond-invalid-operation",
