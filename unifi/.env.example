# UniFi UDM Pro SSH credentials
# Copy to .env and fill in values from UniFi Network → Settings → System → Advanced → Device SSH Authentication
#
# UNIFI_SSH_USER: Console SSH uses "root"; Device SSH uses a generated value
# UNIFI_SSH_PASSWORD: Password you set for SSH access
# UNIFI_SSH_HOST: UDM Pro IP (default: 192.168.0.1)
#
UNIFI_SSH_USER=""
UNIFI_SSH_PASSWORD=""
UNIFI_SSH_HOST="192.168.0.1"
