#!/usr/bin/env python3
"""Entry point for fa CLI.

  fa              enter interactive shell (fa> prompt; like SSH)
  fa list         list modules and state
  fa enable follow
  fa check        verify backend when follow is on but agent is not following
  fa help, fa '?' show all commands

In the shell: type commands, exit/quit/q to leave.
Add this directory to PATH or symlink to ~/bin to run from anywhere.
"""
import os
import sys

script_dir = os.path.dirname(os.path.abspath(__file__))
os.chdir(script_dir)
if script_dir not in sys.path:
    sys.path.insert(0, script_dir)

from agent_control import main

if __name__ == "__main__":
    main()
