#!/usr/bin/env python3
"""
LG C5 Monitor Control - Port 9761 Binary Protocol Investigation
Investigates what protocol port 9761 actually uses
"""

import socket
import time
import sys

def investigate_port_9761(ip_address):
    """Investigate what protocol port 9761 uses"""
    try:
        # Create socket connection
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(10)
        sock.connect((ip_address, 9761))
        
        print(f"🔌 Connected to {ip_address}:9761")
        
        # Send some test data to see what happens
        test_messages = [
            b"hello",
            b"GET / HTTP/1.1\r\n\r\n",
            b"{\"type\":\"test\"}\n",
            b"82888",
            b"QDF6T3HV"
        ]
        
        for i, message in enumerate(test_messages):
            print(f"📤 Sending test message {i+1}: {message}")
            sock.send(message)
            
            # Wait for response
            try:
                response = sock.recv(1024)
                print(f"📥 Response {i+1}: {response}")
                print(f"📥 Response hex: {response.hex()}")
                print(f"📥 Response ascii: {response.decode('ascii', errors='ignore')}")
                print("-" * 50)
            except Exception as e:
                print(f"📥 No response for message {i+1}: {e}")
                print("-" * 50)
            
            time.sleep(1)
        
        sock.close()
        return True
        
    except Exception as e:
        print(f"❌ Investigation failed: {e}")
        return False

def main():
    if len(sys.argv) != 2:
        print("Usage: python3 investigate_9761.py <ip_address>")
        sys.exit(1)
    
    ip_address = sys.argv[1]
    print(f"🔍 Investigating port 9761 protocol on {ip_address}")
    print("=" * 60)
    
    success = investigate_port_9761(ip_address)
    if success:
        print("✅ Investigation completed")
    else:
        print("❌ Investigation failed")
        sys.exit(1)

if __name__ == "__main__":
    main()
