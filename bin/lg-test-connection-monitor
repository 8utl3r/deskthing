#!/usr/bin/env python3
"""
LG C5 Connection Monitor
Monitor what the TV sends when we first connect
"""

import socket
import sys
import time
from datetime import datetime

def log(message, level="INFO"):
    timestamp = datetime.now().strftime("%H:%M:%S.%f")[:-3]
    print(f"[{timestamp}] {level}: {message}")

def monitor_connection(tv_ip, port, duration=10):
    """Monitor what the TV sends when we connect"""
    log(f"Monitoring connection to {tv_ip}:{port} for {duration} seconds...")
    
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(1)
        sock.connect((tv_ip, port))
        log(f"✅ Connected to {tv_ip}:{port}")
        
        # Monitor for incoming data
        start_time = time.time()
        data_received = False
        
        while time.time() - start_time < duration:
            try:
                sock.settimeout(1)
                data = sock.recv(1024)
                if data:
                    data_received = True
                    hex_data = data.hex()
                    ascii_data = ''.join([chr(b) if 32 <= b <= 126 else f'\\x{b:02x}' for b in data])
                    log(f"📥 Received: {hex_data} | {ascii_data}")
                else:
                    time.sleep(0.1)
            except socket.timeout:
                time.sleep(0.1)
                continue
        
        if not data_received:
            log(f"❌ No data received from {tv_ip}:{port} in {duration} seconds")
        
        sock.close()
        return data_received
        
    except Exception as e:
        log(f"❌ Connection failed: {e}", "ERROR")
        return False

def test_handshake_sequences(tv_ip, port):
    """Test various handshake sequences"""
    log(f"Testing handshake sequences on {tv_ip}:{port}")
    
    handshake_sequences = [
        # WebOS API handshake
        b"GET / HTTP/1.1\r\nHost: " + tv_ip.encode() + b"\r\n\r\n",
        b"POST / HTTP/1.1\r\nHost: " + tv_ip.encode() + b"\r\nContent-Length: 0\r\n\r\n",
        
        # Simple TCP handshake
        b"HELLO\r\n",
        b"CONNECT\r\n",
        b"AUTH\r\n",
        
        # LG specific handshakes
        b"LGTV\r\n",
        b"LG\r\n",
        b"TV\r\n",
        
        # Empty data
        b"",
        b"\r\n",
        b"\n",
        b"\r",
    ]
    
    for i, handshake in enumerate(handshake_sequences):
        log(f"Testing handshake {i+1}: {handshake}")
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(3)
            sock.connect((tv_ip, port))
            
            if handshake:
                sock.send(handshake)
            
            # Wait for response
            sock.settimeout(2)
            try:
                response = sock.recv(1024)
                if response:
                    hex_data = response.hex()
                    ascii_data = ''.join([chr(b) if 32 <= b <= 126 else f'\\x{b:02x}' for b in response])
                    log(f"🎉 SUCCESS! Handshake {i+1} got response: {hex_data} | {ascii_data}")
                    sock.close()
                    return True
                else:
                    log(f"No response to handshake {i+1}")
            except socket.timeout:
                log(f"Timeout for handshake {i+1}")
            
            sock.close()
            time.sleep(0.5)
            
        except Exception as e:
            log(f"Handshake {i+1} failed: {e}")
    
    return False

def main():
    if len(sys.argv) < 2:
        print("Usage: python3 lg-test-connection-monitor <tv_ip>")
        sys.exit(1)
    
    tv_ip = sys.argv[1]
    
    log(f"🔍 Connection monitoring for {tv_ip}")
    
    # Test all open ports
    ports_to_test = [3000, 3001, 9761]
    
    for port in ports_to_test:
        log(f"\n=== Testing Port {port} ===")
        
        # Test 1: Monitor connection
        if monitor_connection(tv_ip, port, 5):
            log(f"✅ Port {port} sent data!")
            continue
        
        # Test 2: Test handshake sequences
        if test_handshake_sequences(tv_ip, port):
            log(f"✅ Port {port} responded to handshake!")
            continue
        
        log(f"❌ Port {port} is not responsive")
    
    log(f"\n📊 Summary: All ports are open but none respond to any commands or handshakes")

if __name__ == "__main__":
    main()
