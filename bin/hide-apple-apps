#!/usr/bin/env bash
# Hide/unhide Apple apps in /Applications and reset Dock pins.
# - SIP-protected apps in /System/Applications cannot be modified without disabling SIP; skipped safely.
# Usage:
#   hide-apple-apps --dry-run                # preview actions
#   hide-apple-apps --apply                  # perform actions
#   hide-apple-apps --apply --unhide         # reverse hiding
#   hide-apple-apps --apply --clear-dock     # clear Dock persistent apps and recents
set -euo pipefail

APPLY=0
UNHIDE=0
CLEAR_DOCK=0

for arg in "$@"; do
  case "$arg" in
    --apply) APPLY=1 ;;
    --dry-run) APPLY=0 ;;
    --unhide) UNHIDE=1 ;;
    --clear-dock) CLEAR_DOCK=1 ;;
    *) echo "Unknown arg: $arg" >&2; exit 2 ;;
  esac
done

act() {
  if [[ $APPLY -eq 1 ]]; then
    eval "$1"
  else
    echo "DRY: $1"
  fi
}

# Customize this list to your preferences. Entries under /System/Applications will be reported as SKIP.
HIDE_APPS=(
  # Removable from /Applications (if installed)
  "GarageBand.app"
  "iMovie.app"
  "Keynote.app"
  "Numbers.app"
  "Pages.app"
  # Common system apps (SIP-protected; will be SKIP but listed for visibility)
  "Music.app"
  "TV.app"
  "Podcasts.app"
  "Photos.app"
  "Photo Booth.app"
  "Mail.app"
  "Messages.app"
  "FaceTime.app"
  "Calendar.app"
  "Reminders.app"
  "Notes.app"
  "Maps.app"
  "Books.app"
  "Freeform.app"
  "News.app"
  "Stocks.app"
  "Weather.app"
  "Home.app"
  "Shortcuts.app"
  "Voice Memos.app"
  "Stickies.app"
  "Safari.app"
  "App Store.app"
  "Preview.app"
  "QuickTime Player.app"
)

hide_one() {
  local app_name="$1"
  local sys_path="/System/Applications/$app_name"
  local usr_path="/Applications/$app_name"
  local flag="hidden"; [[ $UNHIDE -eq 1 ]] && flag="nohidden"

  if [[ -e "$usr_path" ]]; then
    echo "FLAG $flag: $usr_path"
    act "chflags $flag \"$usr_path\""
  elif [[ -e "$sys_path" ]]; then
    echo "SKIP (SIP protected): $sys_path"
  else
    echo "MISSING: $app_name"
  fi
}

for app in "${HIDE_APPS[@]}"; do
  hide_one "$app"
done

if [[ $CLEAR_DOCK -eq 1 ]]; then
  echo "Clearing Dock persistent apps and recent apps (Finder cannot be removed)."
  act "defaults write com.apple.dock persistent-apps -array"
  act "defaults write com.apple.dock show-recents -bool false"
  act "killall Dock 2>/dev/null || true"
fi

echo "Done. Mode: $([[ $APPLY -eq 1 ]] && echo APPLY || echo DRY-RUN)."
