#!/usr/bin/env bash
set -euo pipefail
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

"$REPO_ROOT/bin/snapshot" || true

if git diff --quiet && git diff --cached --quiet; then
  echo "No changes to commit."
else
  git add -A
  git commit -m "chore(snapshot): update Brewfile and inventory" || true
fi
