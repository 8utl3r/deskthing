#!/usr/bin/env python3
"""
LG C5 Monitor Interactive Terminal
Opens a persistent connection to LG C5 for interactive command sending
"""

import socket
import time
import sys
import subprocess
import os
from typing import Optional

class LGInteractiveTerminal:
    def __init__(self, ip_address: str, port: int = 9761):
        self.ip_address = ip_address
        self.port = port
        self.socket = None
        self.connected = False
        self.script_dir = os.path.dirname(os.path.abspath(__file__))
        
    def log(self, message: str, level: str = "INFO"):
        """Log message with timestamp"""
        timestamp = time.strftime("%H:%M:%S")
        print(f"[{timestamp}] {level}: {message}")
        
    def check_dock_connection(self) -> bool:
        """Check if dock is connected"""
        try:
            dock_script = os.path.join(self.script_dir, "dock-detector-simple")
            if not os.path.exists(dock_script):
                self.log(f"Dock detector script not found: {dock_script}", "ERROR")
                return False
                
            result = subprocess.run(
                [dock_script],
                capture_output=True,
                text=True,
                check=False,
                timeout=5
            )
            
            if result.returncode == 0:
                self.log("Dock detected - LG C5 control enabled")
                return True
            else:
                self.log("No dock detected - LG C5 control disabled")
                return False
                
        except Exception as e:
            self.log(f"Dock detection failed: {e}", "ERROR")
            return False
    
    def connect(self) -> bool:
        """Establish connection to LG TV"""
        if not self.check_dock_connection():
            return False
        
        try:
            self.log(f"Connecting to {self.ip_address}:{self.port}")
            
            # Create socket connection
            self.socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            self.socket.settimeout(10)
            self.socket.connect((self.ip_address, self.port))
            
            self.connected = True
            self.log("Connected successfully!")
            return True
            
        except Exception as e:
            self.log(f"Connection failed: {e}", "ERROR")
            return False
    
    def disconnect(self):
        """Close connection"""
        if self.socket:
            try:
                self.socket.close()
                self.log("Disconnected")
            except:
                pass
            finally:
                self.socket = None
                self.connected = False
    
    def send_command(self, command: str, expect_response: bool = False) -> Optional[str]:
        """Send command to LG TV"""
        if not self.connected or not self.socket:
            self.log("Not connected to TV", "ERROR")
            return None
            
        try:
            print(f"→ {command}")
            
            # Send command as plain text
            command_bytes = command.encode('utf-8')
            self.socket.send(command_bytes)
            
            # Add carriage return (0x0D) as postfix
            self.socket.send(b'\x0D')
            
            if expect_response:
                # Wait for response (terminated by 0x0A)
                response = b""
                start_time = time.time()
                
                while time.time() - start_time < 5:  # 5 second timeout
                    try:
                        data = self.socket.recv(1024)
                        if not data:
                            break
                        response += data
                        if b'\x0A' in response:
                            break
                    except socket.timeout:
                        break
                
                if response:
                    response_str = response.decode('utf-8', errors='ignore')
                    print(f"← {response_str}")
                    return response_str
                else:
                    print("← (no response)")
                    return None
            else:
                print("← OK")
                return "OK"
            
        except Exception as e:
            print(f"← ERROR: {e}")
            return None
    
    def show_help(self):
        """Show available commands"""
        print("\n📺 LG C5 Interactive Terminal Commands:")
        print("=" * 50)
        print("Power Control:")
        print("  power on     - Turn TV on (Wake-on-LAN)")
        print("  power off    - Turn TV off")
        print("")
        print("Volume Control:")
        print("  vol up       - Volume up")
        print("  vol down     - Volume down")
        print("  mute on      - Mute")
        print("  mute off     - Unmute")
        print("")
        print("Input Control:")
        print("  input hdmi1  - Switch to HDMI 1")
        print("  input hdmi2  - Switch to HDMI 2")
        print("  input hdmi3  - Switch to HDMI 3")
        print("  input hdmi4  - Switch to HDMI 4")
        print("")
        print("Status:")
        print("  volume       - Get current volume")
        print("  mute         - Get mute status")
        print("  status       - Get TV status")
        print("")
        print("Other:")
        print("  help         - Show this help")
        print("  quit/exit    - Exit terminal")
        print("  raw <cmd>    - Send raw command")
        print("=" * 50)
    
    def run(self):
        """Run interactive terminal"""
        if not self.connect():
            self.log("Failed to connect to TV. Exiting.")
            return
        
        print("\n🎮 LG C5 Interactive Terminal")
        print("Type 'help' for available commands, 'quit' to exit")
        print("-" * 50)
        
        try:
            while True:
                try:
                    command = input("\nLG> ").strip()
                    
                    if not command:
                        continue
                    
                    if command.lower() in ['quit', 'exit', 'q']:
                        print("Goodbye!")
                        break
                    
                    elif command.lower() == 'help':
                        self.show_help()
                    
                    elif command.lower() == 'power on':
                        # Use Wake-on-LAN for power on
                        wol_script = os.path.join(self.script_dir, "lg-monitor-wol")
                        if os.path.exists(wol_script):
                            result = subprocess.run(
                                [wol_script, self.ip_address, "on", "--no-dock-check"],
                                capture_output=True,
                                text=True,
                                check=False,
                                timeout=10
                            )
                            if result.returncode == 0:
                                print("→ Wake-on-LAN packet sent")
                                print("← Power on command sent successfully")
                            else:
                                print("← ERROR: Wake-on-LAN failed")
                        else:
                            print("← ERROR: Wake-on-LAN script not found")
                    
                    elif command.lower() == 'power off':
                        self.send_command("POWER off")
                    
                    elif command.lower() == 'vol up':
                        self.send_command("KEY_ACTION volumeup")
                    
                    elif command.lower() == 'vol down':
                        self.send_command("KEY_ACTION volumedown")
                    
                    elif command.lower() == 'mute on':
                        self.send_command("VOLUME_MUTE on")
                    
                    elif command.lower() == 'mute off':
                        self.send_command("VOLUME_MUTE off")
                    
                    elif command.lower().startswith('input '):
                        input_name = command[6:].strip()
                        self.send_command(f"KEY_ACTION {input_name}")
                    
                    elif command.lower() == 'volume':
                        self.send_command("VOLUME", expect_response=True)
                    
                    elif command.lower() == 'mute':
                        self.send_command("MUTE", expect_response=True)
                    
                    elif command.lower() == 'status':
                        print("→ Getting TV status...")
                        vol_response = self.send_command("VOLUME", expect_response=True)
                        mute_response = self.send_command("MUTE", expect_response=True)
                        print(f"← Status: Volume={vol_response}, Mute={mute_response}")
                    
                    elif command.lower().startswith('raw '):
                        raw_command = command[4:].strip()
                        self.send_command(raw_command, expect_response=True)
                    
                    else:
                        print(f"Unknown command: {command}")
                        print("Type 'help' for available commands")
                
                except KeyboardInterrupt:
                    print("\nUse 'quit' to exit")
                    continue
                except EOFError:
                    break
        
        finally:
            self.disconnect()

def main():
    if len(sys.argv) != 2:
        print("Usage: lg-terminal <ip_address>")
        print("Example: lg-terminal 192.168.0.39")
        sys.exit(1)
    
    ip_address = sys.argv[1]
    terminal = LGInteractiveTerminal(ip_address)
    terminal.run()

if __name__ == "__main__":
    main()

