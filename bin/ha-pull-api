#!/usr/bin/env bash
# Home Assistant Configuration Pull via API
# Downloads existing configuration from Home Assistant server using the API

set -euo pipefail

HA_SERVER="192.168.0.105"
HA_PORT="8123"
HA_TOKEN="${HA_TOKEN:-}"
BACKUP_DIR="${BACKUP_DIR:-./homeassistant/backup}"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

usage() {
    echo "Usage: $0 [OPTIONS]"
    echo "Options:"
    echo "  --token TOKEN      Home Assistant API token"
    echo "  --backup-dir DIR   Directory to store downloaded configs (default: ./homeassistant/backup)"
    echo "  --dry-run          Show what would be downloaded without actually downloading"
    echo "  --help             Show this help message"
    echo ""
    echo "Environment variables:"
    echo "  HA_TOKEN           Home Assistant API token"
    echo "  BACKUP_DIR         Local backup directory (default: ./homeassistant/backup)"
    echo ""
    echo "To get your API token:"
    echo "1. Go to http://$HA_SERVER:$HA_PORT/profile"
    echo "2. Scroll down to 'Long-lived access tokens'"
    echo "3. Click 'Create token'"
    echo "4. Copy the token and use it with --token or set HA_TOKEN environment variable"
}

check_token() {
    if [[ -z "$HA_TOKEN" ]]; then
        echo -e "${RED}Error: Home Assistant API token is required${NC}"
        echo ""
        echo "Get your token from: http://$HA_SERVER:$HA_PORT/profile"
        echo "Then run: $0 --token YOUR_TOKEN"
        echo "Or set: export HA_TOKEN=YOUR_TOKEN"
        exit 1
    fi
}

test_connection() {
    echo -e "${BLUE}Testing connection to Home Assistant...${NC}"
    
    local api_url="http://$HA_SERVER:$HA_PORT/api/"
    local response
    
    if response=$(curl -s -w "%{http_code}" -H "Authorization: Bearer $HA_TOKEN" "$api_url"); then
        local http_code="${response: -3}"
        if [[ "$http_code" == "200" ]]; then
            echo -e "${GREEN}✓ Connected to Home Assistant${NC}"
            return 0
        else
            echo -e "${RED}✗ Connection failed (HTTP $http_code)${NC}"
            return 1
        fi
    else
        echo -e "${RED}✗ Failed to connect to Home Assistant${NC}"
        return 1
    fi
}

download_config_file() {
    local filename="$1"
    local local_file="$2"
    
    echo -e "${BLUE}Downloading $filename...${NC}"
    
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "Would download: $filename -> $local_file"
        return 0
    fi
    
    local api_url="http://$HA_SERVER:$HA_PORT/api/config/core/check_config"
    
    # Try to get the file content via API
    # Note: Home Assistant API doesn't directly expose config files, so we'll use a different approach
    echo -e "${YELLOW}Note: Home Assistant API doesn't directly expose config files${NC}"
    echo -e "${YELLOW}We'll need to use an alternative method${NC}"
    return 1
}

create_backup_dir() {
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "Would create backup directory: $BACKUP_DIR"
        return 0
    fi
    
    if [[ ! -d "$BACKUP_DIR" ]]; then
        mkdir -p "$BACKUP_DIR"
        echo -e "${GREEN}✓ Created backup directory: $BACKUP_DIR${NC}"
    else
        echo -e "${YELLOW}Backup directory already exists: $BACKUP_DIR${NC}"
    fi
}

get_entities() {
    echo -e "${BLUE}Getting entities from Home Assistant...${NC}"
    
    local api_url="http://$HA_SERVER:$HA_PORT/api/states"
    local entities_file="$BACKUP_DIR/entities.json"
    
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "Would download entities to: $entities_file"
        return 0
    fi
    
    if curl -s -H "Authorization: Bearer $HA_TOKEN" "$api_url" > "$entities_file"; then
        echo -e "${GREEN}✓ Downloaded entities to $entities_file${NC}"
        return 0
    else
        echo -e "${RED}✗ Failed to download entities${NC}"
        return 1
    fi
}

get_services() {
    echo -e "${BLUE}Getting services from Home Assistant...${NC}"
    
    local api_url="http://$HA_SERVER:$HA_PORT/api/services"
    local services_file="$BACKUP_DIR/services.json"
    
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "Would download services to: $services_file"
        return 0
    fi
    
    if curl -s -H "Authorization: Bearer $HA_TOKEN" "$api_url" > "$services_file"; then
        echo -e "${GREEN}✓ Downloaded services to $services_file${NC}"
        return 0
    else
        echo -e "${RED}✗ Failed to download services${NC}"
        return 1
    fi
}

get_config_info() {
    echo -e "${BLUE}Getting Home Assistant configuration info...${NC}"
    
    local api_url="http://$HA_SERVER:$HA_PORT/api/config"
    local config_file="$BACKUP_DIR/config_info.json"
    
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "Would download config info to: $config_file"
        return 0
    fi
    
    if curl -s -H "Authorization: Bearer $HA_TOKEN" "$api_url" > "$config_file"; then
        echo -e "${GREEN}✓ Downloaded config info to $config_file${NC}"
        return 0
    else
        echo -e "${RED}✗ Failed to download config info${NC}"
        return 1
    fi
}

main() {
    DRY_RUN="false"
    
    # Parse command line arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --token)
                HA_TOKEN="$2"
                shift 2
                ;;
            --backup-dir)
                BACKUP_DIR="$2"
                shift 2
                ;;
            --dry-run)
                DRY_RUN="true"
                shift
                ;;
            --help)
                usage
                exit 0
                ;;
            *)
                echo "Unknown option: $1"
                usage
                exit 1
                ;;
        esac
    done
    
    echo -e "${GREEN}Home Assistant Configuration Pull (API)${NC}"
    echo "Server: http://$HA_SERVER:$HA_PORT"
    echo "Backup Dir: $BACKUP_DIR"
    echo ""
    
    # Check if token is provided
    check_token
    
    # Create backup directory
    create_backup_dir
    
    # Test connection
    if ! test_connection; then
        echo -e "${RED}Failed to connect to Home Assistant${NC}"
        echo "Please check:"
        echo "1. Home Assistant is running at $HA_SERVER:$HA_PORT"
        echo "2. Your API token is correct"
        echo "3. Your network connection is working"
        exit 1
    fi
    
    echo ""
    
    # Download what we can via API
    local failed_downloads=()
    
    if ! get_entities; then
        failed_downloads+=("entities")
    fi
    
    if ! get_services; then
        failed_downloads+=("services")
    fi
    
    if ! get_config_info; then
        failed_downloads+=("config_info")
    fi
    
    echo ""
    echo -e "${GREEN}Download Summary:${NC}"
    
    if [[ ${#failed_downloads[@]} -eq 0 ]]; then
        echo -e "${GREEN}✓ Successfully downloaded all available data${NC}"
    else
        echo -e "${YELLOW}⚠ Some downloads failed: ${failed_downloads[*]}${NC}"
    fi
    
    if [[ "$DRY_RUN" == "false" ]]; then
        echo ""
        echo -e "${BLUE}Next steps:${NC}"
        echo "1. Review downloaded files in: $BACKUP_DIR"
        echo "2. For actual config files, you'll need to:"
        echo "   - Access Home Assistant via SSH/terminal"
        echo "   - Or use the Home Assistant file editor"
        echo "   - Or manually copy files from the server"
        echo "3. Compare with dotfiles configuration"
        echo "4. Merge any missing configurations"
    fi
    
    echo ""
    echo -e "${YELLOW}Note: Home Assistant API doesn't expose raw config files${NC}"
    echo -e "${YELLOW}For actual YAML files, you'll need direct file system access${NC}"
}

main "$@"
