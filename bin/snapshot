#!/usr/bin/env bash
set -euo pipefail
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
STATE_DIR="$REPO_ROOT/state"
mkdir -p "$STATE_DIR"

if command -v brew >/dev/null 2>&1; then
  brew bundle dump --file "$REPO_ROOT/Brewfile" --force --describe || true
  brew tap > "$STATE_DIR/brew-taps.txt" || true
  brew list --formula > "$STATE_DIR/brew-formulae.txt" || true
  brew list --cask > "$STATE_DIR/brew-casks.txt" || true
fi

ls -1 /Applications > "$STATE_DIR/apps-system.txt" 2>/dev/null || true
ls -1 "$HOME/Applications" > "$STATE_DIR/apps-user.txt" 2>/dev/null || true

if command -v tailscale >/dev/null 2>&1; then
  tailscale version > "$STATE_DIR/tailscale-version.txt" || true
fi

echo "Snapshot complete in $STATE_DIR"
