#!/usr/bin/env bash
# Home Assistant Configuration Sync Script
# Syncs local dotfiles configuration to remote Home Assistant server

set -euo pipefail

HA_SERVER="192.168.0.105"
HA_PORT="8123"
HA_USER="${HA_USER:-homeassistant}"
HA_CONFIG_DIR="${HA_CONFIG_DIR:-/config}"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

usage() {
    echo "Usage: $0 [OPTIONS]"
    echo "Options:"
    echo "  --dry-run     Show what would be synced without actually syncing"
    echo "  --validate    Validate YAML files before syncing"
    echo "  --help        Show this help message"
    echo ""
    echo "Environment variables:"
    echo "  HA_USER       Home Assistant server username (default: homeassistant)"
    echo "  HA_CONFIG_DIR Home Assistant config directory (default: /config)"
}

validate_yaml() {
    local file="$1"
    echo -e "${YELLOW}Validating $file...${NC}"
    
    if command -v yq >/dev/null 2>&1; then
        if yq eval '.' "$file" >/dev/null 2>&1; then
            echo -e "${GREEN}✓ $file is valid YAML${NC}"
            return 0
        else
            echo -e "${RED}✗ $file has YAML syntax errors${NC}"
            return 1
        fi
    else
        echo -e "${YELLOW}Warning: yq not found, skipping YAML validation${NC}"
        return 0
    fi
}

sync_file() {
    local local_file="$1"
    local remote_file="$2"
    
    if [[ ! -f "$local_file" ]]; then
        echo -e "${RED}Error: Local file $local_file not found${NC}"
        return 1
    fi
    
    echo -e "${YELLOW}Syncing $local_file -> $remote_file${NC}"
    
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "Would sync: $local_file -> $HA_USER@$HA_SERVER:$remote_file"
        return 0
    fi
    
    # Use scp to copy file to remote server
    if scp "$local_file" "$HA_USER@$HA_SERVER:$remote_file"; then
        echo -e "${GREEN}✓ Successfully synced $local_file${NC}"
        return 0
    else
        echo -e "${RED}✗ Failed to sync $local_file${NC}"
        return 1
    fi
}

reload_config() {
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "Would reload Home Assistant configuration"
        return 0
    fi
    
    echo -e "${YELLOW}Reloading Home Assistant configuration...${NC}"
    
    # Use Home Assistant API to reload configuration
    local api_url="http://$HA_SERVER:$HA_PORT/api/services/homeassistant/reload_config_entry"
    
    if curl -s -X POST "$api_url" >/dev/null 2>&1; then
        echo -e "${GREEN}✓ Configuration reloaded${NC}"
    else
        echo -e "${YELLOW}Warning: Could not reload configuration via API${NC}"
        echo "You may need to restart Home Assistant manually"
    fi
}

main() {
    DRY_RUN="false"
    VALIDATE="false"
    
    # Parse command line arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --dry-run)
                DRY_RUN="true"
                shift
                ;;
            --validate)
                VALIDATE="true"
                shift
                ;;
            --help)
                usage
                exit 0
                ;;
            *)
                echo "Unknown option: $1"
                usage
                exit 1
                ;;
        esac
    done
    
    echo -e "${GREEN}Home Assistant Configuration Sync${NC}"
    echo "Server: $HA_SERVER:$HA_PORT"
    echo "User: $HA_USER"
    echo "Config Dir: $HA_CONFIG_DIR"
    echo ""
    
    # Get script directory
    script_dir="$(cd "$(dirname "$0")" && pwd)"
    ha_dir="$script_dir/homeassistant"
    
    if [[ ! -d "$ha_dir" ]]; then
        echo -e "${RED}Error: Home Assistant directory not found at $ha_dir${NC}"
        exit 1
    fi
    
    # Files to sync
    files=(
        "configuration.yaml"
        "automations.yaml"
        "scripts.yaml"
        "groups.yaml"
        "scenes.yaml"
    )
    
    failed_files=()
    
    for file in "${files[@]}"; do
        local_file="$ha_dir/$file"
        remote_file="$HA_CONFIG_DIR/$file"
        
        if [[ "$VALIDATE" == "true" ]]; then
            if ! validate_yaml "$local_file"; then
                failed_files+=("$file")
                continue
            fi
        fi
        
        if ! sync_file "$local_file" "$remote_file"; then
            failed_files+=("$file")
        fi
    done
    
    if [[ ${#failed_files[@]} -eq 0 ]]; then
        echo -e "${GREEN}✓ All files synced successfully${NC}"
        reload_config
    else
        echo -e "${RED}✗ Failed to sync: ${failed_files[*]}${NC}"
        exit 1
    fi
}

main "$@"
