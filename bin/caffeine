#!/usr/bin/env bash
# Simple caffeine script to prevent sleep
set -euo pipefail

usage() {
    echo "Usage: $0 [on|off|status]"
    echo "  on     - Prevent sleep"
    echo "  off    - Allow sleep"
    echo "  status - Show current status"
    exit 1
}

check_status() {
    local sleep_time=$(pmset -g | grep "sleep" | head -1 | awk '{print $2}')
    local display_sleep=$(pmset -g | grep "displaysleep" | awk '{print $2}')
    
    echo "Current sleep settings:"
    echo "  Computer sleep: ${sleep_time} minutes"
    echo "  Display sleep: ${display_sleep} minutes"
    
    if [[ "$sleep_time" == "0" && "$display_sleep" == "0" ]]; then
        echo "Status: AWAKE (sleep prevented)"
    else
        echo "Status: SLEEP (normal sleep enabled)"
    fi
}

case "${1:-}" in
    on)
        echo "Preventing sleep..."
        sudo pmset -a sleep 0 displaysleep 0
        echo "✅ Sleep prevented"
        ;;
    off)
        echo "Enabling sleep..."
        sudo pmset -a sleep 10 displaysleep 10
        echo "✅ Sleep enabled"
        ;;
    status)
        check_status
        ;;
    *)
        usage
        ;;
esac
