#!/usr/bin/env python3
"""
Simple Dock Detection Script for LG C5 Monitor Control
Uses ioreg to detect dock connection
"""

import subprocess
import sys
import json
from typing import List, Dict

class DockDetector:
    def __init__(self):
        # Dock identifiers based on your current setup
        self.dock_identifiers = [
            # ASIX Ethernet (your current dock)
            {"vendor_id": "0x0b95", "product_id": "0x1790", "name": "ASIX Ethernet (Dock)"},
            # Common dock hubs
            {"vendor_id": "0x2109", "product_id": "0x0824", "name": "VIA Labs USB Hub (Dock)"},
            {"vendor_id": "0x1a40", "product_id": "0x0101", "name": "Terminus USB Hub (Dock)"},
            {"vendor_id": "0x05e3", "product_id": "0x0626", "name": "Genesys USB Hub (Dock)"},
        ]
    
    def get_usb_devices_ioreg(self) -> List[Dict[str, str]]:
        """Get USB devices using ioreg command"""
        devices = []
        try:
            # Get USB device tree
            result = subprocess.run([
                "ioreg", "-p", "IOUSB", "-w0", "-l"
            ], capture_output=True, text=True, check=True)
            
            lines = result.stdout.split('\n')
            current_device = {}
            
            for line in lines:
                line = line.strip()
                
                # Extract device information
                if '"idVendor"' in line:
                    vendor_id = line.split('=')[1].strip().strip('"')
                    current_device['vendor_id'] = f"0x{vendor_id.lower()}"
                elif '"idProduct"' in line:
                    product_id = line.split('=')[1].strip().strip('"')
                    current_device['product_id'] = f"0x{product_id.lower()}"
                elif '"USB Product Name"' in line:
                    name = line.split('=')[1].strip().strip('"')
                    current_device['name'] = name
                elif '"USB Vendor Name"' in line:
                    manufacturer = line.split('=')[1].strip().strip('"')
                    current_device['manufacturer'] = manufacturer
                elif line == "}" and current_device:
                    # End of device block
                    if 'vendor_id' in current_device and 'product_id' in current_device:
                        if 'name' not in current_device:
                            current_device['name'] = 'Unknown Device'
                        if 'manufacturer' not in current_device:
                            current_device['manufacturer'] = 'Unknown'
                        devices.append(current_device.copy())
                    current_device = {}
                    
        except Exception as e:
            print(f"Error getting USB devices: {e}", file=sys.stderr)
        
        return devices
    
    def is_dock_connected(self) -> bool:
        """Check if any known dock is connected"""
        devices = self.get_usb_devices_ioreg()
        
        for device in devices:
            for dock in self.dock_identifiers:
                if (device["vendor_id"] == dock["vendor_id"] and 
                    device["product_id"] == dock["product_id"]):
                    return True
        
        return False
    
    def get_connected_docks(self) -> List[Dict[str, str]]:
        """Get list of connected docks"""
        devices = self.get_usb_devices_ioreg()
        connected_docks = []
        
        for device in devices:
            for dock in self.dock_identifiers:
                if (device["vendor_id"] == dock["vendor_id"] and 
                    device["product_id"] == dock["product_id"]):
                    connected_docks.append({
                        "name": dock["name"],
                        "device_name": device["name"],
                        "manufacturer": device["manufacturer"],
                        "vendor_id": device["vendor_id"],
                        "product_id": device["product_id"]
                    })
        
        return connected_docks
    
    def list_all_devices(self) -> None:
        """List all connected USB devices for debugging"""
        devices = self.get_usb_devices_ioreg()
        print("Connected USB Devices:")
        print("=" * 50)
        
        for device in devices:
            print(f"Name: {device.get('name', 'Unknown')}")
            print(f"Manufacturer: {device.get('manufacturer', 'Unknown')}")
            print(f"Vendor ID: {device.get('vendor_id', 'Unknown')}")
            print(f"Product ID: {device.get('product_id', 'Unknown')}")
            print("-" * 30)

def main():
    detector = DockDetector()
    
    if len(sys.argv) > 1:
        command = sys.argv[1]
        
        if command == "check":
            # Simple check - return 0 if dock connected, 1 if not
            if detector.is_dock_connected():
                print("Dock connected")
                sys.exit(0)
            else:
                print("No dock detected")
                sys.exit(1)
        
        elif command == "list":
            # List all USB devices
            detector.list_all_devices()
        
        elif command == "docks":
            # List connected docks
            docks = detector.get_connected_docks()
            if docks:
                print("Connected Docks:")
                for dock in docks:
                    print(f"- {dock['name']} ({dock['manufacturer']})")
            else:
                print("No docks detected")
        
        elif command == "json":
            # Return JSON output for scripting
            result = {
                "dock_connected": detector.is_dock_connected(),
                "connected_docks": detector.get_connected_docks()
            }
            print(json.dumps(result))
        
        else:
            print("Usage: dock-detector [check|list|docks|json]")
            sys.exit(1)
    else:
        # Default: check if dock is connected
        if detector.is_dock_connected():
            print("✅ Dock connected - LG C5 control enabled")
            sys.exit(0)
        else:
            print("❌ No dock detected - LG C5 control disabled")
            sys.exit(1)

if __name__ == "__main__":
    main()