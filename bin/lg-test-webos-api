#!/usr/bin/env python3
"""
LG C5 webOS API Test
Test the webOS API that Home Assistant uses for LG TV control
"""

import socket
import sys
import time
import json
from datetime import datetime

def log(message, level="INFO"):
    timestamp = datetime.now().strftime("%H:%M:%S.%f")[:-3]
    print(f"[{timestamp}] {level}: {message}")

def test_webos_api(tv_ip, tv_port=3000):
    """Test webOS API connection and commands"""
    log(f"Testing webOS API on {tv_ip}:{tv_port}")
    
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(5)
        sock.connect((tv_ip, tv_port))
        log("✅ Connected to webOS API")
        
        # Test 1: Basic webOS API handshake
        log("Testing webOS API handshake...")
        
        # Send webOS API request
        request = {
            "type": "request",
            "id": "test_1",
            "uri": "ssap://system/getSystemInfo"
        }
        
        request_json = json.dumps(request) + "\n"
        log(f"Sending: {request_json.strip()}")
        sock.send(request_json.encode('utf-8'))
        
        # Wait for response
        sock.settimeout(3)
        try:
            response = sock.recv(1024)
            if response:
                log(f"📥 Response: {response.decode('utf-8', errors='ignore')}")
                sock.close()
                return True
            else:
                log("No response to webOS API request")
        except socket.timeout:
            log("webOS API response timeout")
        
        sock.close()
        return False
        
    except Exception as e:
        log(f"❌ webOS API test failed: {e}", "ERROR")
        return False

def test_webos_commands(tv_ip, tv_port=3000):
    """Test various webOS API commands"""
    log(f"Testing webOS API commands on {tv_ip}:{tv_port}")
    
    # Common webOS API commands
    commands = [
        {"type": "request", "id": "test_1", "uri": "ssap://system/getSystemInfo"},
        {"type": "request", "id": "test_2", "uri": "ssap://audio/getVolume"},
        {"type": "request", "id": "test_3", "uri": "ssap://system/getPowerState"},
        {"type": "request", "id": "test_4", "uri": "ssap://tv/getChannelList"},
        {"type": "request", "id": "test_5", "uri": "ssap://com.webos.service.connectionmanager/getStatus"},
    ]
    
    for i, command in enumerate(commands):
        log(f"Testing command {i+1}: {command['uri']}")
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(5)
            sock.connect((tv_ip, tv_port))
            
            request_json = json.dumps(command) + "\n"
            log(f"Sending: {request_json.strip()}")
            sock.send(request_json.encode('utf-8'))
            
            sock.settimeout(3)
            try:
                response = sock.recv(1024)
                if response:
                    log(f"📥 Response: {response.decode('utf-8', errors='ignore')}")
                    sock.close()
                    return True
                else:
                    log(f"No response to command {i+1}")
            except socket.timeout:
                log(f"Timeout for command {i+1}")
            
            sock.close()
            time.sleep(1)
            
        except Exception as e:
            log(f"Command {i+1} failed: {e}")
    
    return False

def test_webos_control_commands(tv_ip, tv_port=3000):
    """Test webOS API control commands"""
    log(f"Testing webOS API control commands on {tv_ip}:{tv_port}")
    
    # Control commands
    control_commands = [
        {"type": "request", "id": "control_1", "uri": "ssap://audio/setVolume", "payload": {"volume": 15}},
        {"type": "request", "id": "control_2", "uri": "ssap://audio/volumeUp"},
        {"type": "request", "id": "control_3", "uri": "ssap://audio/volumeDown"},
        {"type": "request", "id": "control_4", "uri": "ssap://audio/setMute", "payload": {"mute": True}},
        {"type": "request", "id": "control_5", "uri": "ssap://audio/setMute", "payload": {"mute": False}},
    ]
    
    for i, command in enumerate(control_commands):
        log(f"Testing control command {i+1}: {command['uri']}")
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(5)
            sock.connect((tv_ip, tv_port))
            
            request_json = json.dumps(command) + "\n"
            log(f"Sending: {request_json.strip()}")
            sock.send(request_json.encode('utf-8'))
            
            sock.settimeout(3)
            try:
                response = sock.recv(1024)
                if response:
                    log(f"📥 Response: {response.decode('utf-8', errors='ignore')}")
                    sock.close()
                    return True
                else:
                    log(f"No response to control command {i+1}")
            except socket.timeout:
                log(f"Timeout for control command {i+1}")
            
            sock.close()
            time.sleep(1)
            
        except Exception as e:
            log(f"Control command {i+1} failed: {e}")
    
    return False

def main():
    if len(sys.argv) < 2:
        print("Usage: python3 lg-test-webos-api <tv_ip> [port]")
        sys.exit(1)
    
    tv_ip = sys.argv[1]
    tv_port = int(sys.argv[2]) if len(sys.argv) > 2 else 3000
    
    log(f"🚀 Testing webOS API for {tv_ip}:{tv_port}")
    
    # Test 1: Basic webOS API connection
    if test_webos_api(tv_ip, tv_port):
        log("✅ webOS API is working!")
        return
    
    # Test 2: Try different ports
    for port in [3000, 3001, 8080]:
        if port != tv_port:
            log(f"Trying port {port}...")
            if test_webos_api(tv_ip, port):
                log(f"✅ webOS API works on port {port}!")
                return
    
    # Test 3: Test webOS commands
    if test_webos_commands(tv_ip, tv_port):
        log("✅ webOS commands are working!")
        return
    
    # Test 4: Test control commands
    if test_webos_control_commands(tv_ip, tv_port):
        log("✅ webOS control commands are working!")
        return
    
    log("❌ webOS API is not responding")
    log("This suggests the webOS API is disabled or not available")

if __name__ == "__main__":
    main()
