{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Auto-Commit Watcher: Start",
      "type": "shell",
      "command": "cd ${workspaceFolder} && nohup bash scripts/utilities/auto-commit-watcher > /tmp/auto-commit-watcher-task.log 2>&1 &",
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "panel": "dedicated",
        "showReuseMessage": false
      }
    },
    {
      "label": "Auto-Commit Watcher: Stop",
      "type": "shell",
      "command": "pkill -f auto-commit-watcher || true",
      "problemMatcher": []
    },
    {
      "label": "Auto-Commit Watcher: Status",
      "type": "shell",
      "command": "cat ${env:HOME}/.auto_commit_watcher_status.json 2>/dev/null || echo '{\"status\": \"not running\"}'",
      "problemMatcher": []
    },
    {
      "label": "Auto-Commit Watcher: Show Status (Formatted)",
      "type": "shell",
      "command": "jq -r '\"Status: \" + .status + \" | \" + .message + (if .countdown then \" (\" + (.countdown | tostring) + \"s)\" else \"\" end) + (if .lastCommit then \" | Last: \" + .lastCommit else \"\" end)' ${env:HOME}/.auto_commit_watcher_status.json 2>/dev/null || echo 'Status: not running'",
      "problemMatcher": []
    }
  ]
}
