# Headscale remote CLI configuration
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# HEADSCALE_CLI_ADDRESS: TrueNAS IP and gRPC port (default 50443)
#   The TrueNAS Headscale app may need gRPC port 50443 exposed.
#   If the app only exposes one port (e.g. 30210), try that port.
#
# HEADSCALE_CLI_API_KEY: Create via headscale apikeys create (run on server)
#   See docs/networking/headscale-cli-setup.md for how to create the key.
#
# HEADSCALE_CLI_INSECURE: Set to 1 for LAN-only without TLS (self-signed cert)
#
HEADSCALE_CLI_ADDRESS="192.168.0.158:50443"
HEADSCALE_CLI_API_KEY=""
HEADSCALE_CLI_INSECURE=1
