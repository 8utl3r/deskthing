#!/usr/bin/env bash
set -euo pipefail

APPLY=0
BACKUP_DIR="$HOME/.dotfiles_backup_$(date +%Y%m%d_%H%M%S)"

for arg in "$@"; do
  case "$arg" in
    --apply) APPLY=1 ;;
    --dry-run) APPLY=0 ;;
    *) echo "Unknown arg: $arg" >&2; exit 2 ;;
  esac
done

# Mappings (space-separated src|dest pairs; portable for bash 3.x)
LINK_PAIRS=(
  "shell/.zshrc|$HOME/.zshrc"
  "shell/starship.toml|$HOME/.config/starship.toml"
  "git/.gitconfig|$HOME/.gitconfig"
  "git/.gitignore_global|$HOME/.gitignore_global"
  "git/.gitmessage|$HOME/.gitmessage"
  "runtimes/mise.toml|$HOME/.config/mise/config.toml"
  "terminal/wezterm.lua|$HOME/.wezterm.lua"
  "cursor/settings.json|$HOME/Library/Application Support/Cursor/User/settings.json"
  "cursor/keybindings.json|$HOME/Library/Application Support/Cursor/User/keybindings.json"
  "cursor/snippets|$HOME/Library/Application Support/Cursor/User/snippets"
  "cursor/argv.json|$HOME/Library/Application Support/Cursor/argv.json"
  "cursor/locale.json|$HOME/Library/Application Support/Cursor/User/locale.json"
  "cursor/tasks.json|$HOME/Library/Application Support/Cursor/User/tasks.json"
  "cursor/mcp.json|$HOME/.cursor/mcp.json"
  "aerospace/aerospace.toml|$HOME/.aerospace.toml"
  "karabiner/karabiner.json|$HOME/.config/karabiner/karabiner.json"
  "hammerspoon/init.lua|$HOME/.hammerspoon/init.lua"
  "hammerspoon/shortcut-overlay.lua|$HOME/.hammerspoon/shortcut-overlay.lua"
  "hammerspoon/shortcut-overlay-debug.lua|$HOME/.hammerspoon/shortcut-overlay-debug.lua"
  "hammerspoon/shortcut-overlay-fixed.lua|$HOME/.hammerspoon/shortcut-overlay-fixed.lua"
  "hammerspoon/test-overlay.lua|$HOME/.hammerspoon/test-overlay.lua"
  "hammerspoon/lg-c5|$HOME/.hammerspoon/lg-c5"
  "hammerspoon/home-assistant|$HOME/.hammerspoon/home-assistant"
  "gh/config.yml|$HOME/.config/gh/config.yml"
  "alfred/Alfred.alfredpreferences|$HOME/Library/Application Support/Alfred/Alfred.alfredpreferences"
  "activedock/com.sergey-gerasimenko.ActiveDock-2|$HOME/Library/Application Support/com.sergey-gerasimenko.ActiveDock-2"
  "activedock/com.sergey-gerasimenko.ActiveDock-2.plist|$HOME/Library/Preferences/com.sergey-gerasimenko.ActiveDock-2.plist"
  "bloom/com.asiafu.Bloom.plist|$HOME/Library/Preferences/com.asiafu.Bloom.plist"
  "cheatsheet/com.mediaatelier.CheatSheet.plist|$HOME/Library/Preferences/com.mediaatelier.CheatSheet.plist"
  "flexinet/com.macplus-software.FlexiNet.plist|$HOME/Library/Preferences/com.macplus-software.FlexiNet.plist"
  "ice/com.jordanbaird.Ice.plist|$HOME/Library/Preferences/com.jordanbaird.Ice.plist"
  "docker/config.json|$HOME/.docker/config.json"
  "docker/daemon.json|$HOME/.docker/daemon.json"
  "docker/persisted-state.json|$HOME/Library/Application Support/Docker Desktop/persisted-state.json"
  "docker/window-management.json|$HOME/Library/Application Support/Docker Desktop/window-management.json"
  "homeassistant/configuration.yaml|$HOME/.homeassistant/configuration.yaml"
  "homeassistant/automations.yaml|$HOME/.homeassistant/automations.yaml"
  "homeassistant/scripts.yaml|$HOME/.homeassistant/scripts.yaml"
  "homeassistant/groups.yaml|$HOME/.homeassistant/groups.yaml"
  "homeassistant/scenes.yaml|$HOME/.homeassistant/scenes.yaml"
  ".editorconfig|$HOME/.editorconfig"
)

repo_root="$(cd "$(dirname "$0")/../.." && pwd)"

link_one() {
  local src_rel="$1"
  local dest="$2"
  local src="$repo_root/$src_rel"

  if [[ ! -f "$src" && ! -d "$src" ]]; then
    echo "SKIP: missing source $src_rel"; return
  fi

  local dest_dir
  dest_dir="$(dirname "$dest")"
  if [[ $APPLY -eq 1 ]]; then
    mkdir -p "$dest_dir"
  fi

  if [[ -e "$dest" && ! -L "$dest" ]]; then
    echo "BACKUP: $dest -> $BACKUP_DIR";
    if [[ $APPLY -eq 1 ]]; then
      mkdir -p "$BACKUP_DIR"
      mv "$dest" "$BACKUP_DIR/" 2>/dev/null || true
    fi
  fi

  echo "LINK: $dest -> $src_rel"
  if [[ $APPLY -eq 1 ]]; then
    ln -snf "$src" "$dest"
  fi
}

for pair in "${LINK_PAIRS[@]}"; do
  src_rel="${pair%%|*}"
  dest="${pair#*|}"
  link_one "$src_rel" "$dest"
done

echo "Done. Mode: $([[ $APPLY -eq 1 ]] && echo APPLY || echo DRY-RUN)"
