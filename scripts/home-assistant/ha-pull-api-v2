#!/usr/bin/env bash
# Home Assistant API Configuration Puller
# Uses Home Assistant API to export configuration data

set -euo pipefail

HA_SERVER="192.168.0.105"
HA_PORT="8123"
HA_TOKEN="${HA_TOKEN:-}"
BACKUP_DIR="${BACKUP_DIR:-./homeassistant/backup}"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

usage() {
    echo "Usage: $0 [OPTIONS]"
    echo "Options:"
    echo "  --token TOKEN      Home Assistant API token"
    echo "  --backup-dir DIR   Directory to store exported configs (default: ./homeassistant/backup)"
    echo "  --dry-run          Show what would be downloaded without actually downloading"
    echo "  --help             Show this help message"
    echo ""
    echo "Environment variables:"
    echo "  HA_TOKEN           Home Assistant API token"
    echo "  BACKUP_DIR         Local backup directory (default: ./homeassistant/backup)"
    echo ""
    echo "To get your API token:"
    echo "1. Go to http://$HA_SERVER:$HA_PORT/profile"
    echo "2. Scroll down to 'Long-lived access tokens'"
    echo "3. Click 'Create token'"
    echo "4. Copy the token and use it with --token or set HA_TOKEN environment variable"
}

check_token() {
    if [[ -z "$HA_TOKEN" ]]; then
        echo -e "${RED}Error: Home Assistant API token is required${NC}"
        echo ""
        echo "Get your token from: http://$HA_SERVER:$HA_PORT/profile"
        echo "Then run: $0 --token YOUR_TOKEN"
        echo "Or set: export HA_TOKEN=YOUR_TOKEN"
        exit 1
    fi
}

test_connection() {
    echo -e "${BLUE}Testing connection to Home Assistant...${NC}"
    
    local api_url="http://$HA_SERVER:$HA_PORT/api/"
    local response
    
    if response=$(curl -s -w "%{http_code}" -H "Authorization: Bearer $HA_TOKEN" "$api_url"); then
        local http_code="${response: -3}"
        if [[ "$http_code" == "200" ]]; then
            echo -e "${GREEN}✓ Connected to Home Assistant${NC}"
            return 0
        else
            echo -e "${RED}✗ Connection failed (HTTP $http_code)${NC}"
            return 1
        fi
    else
        echo -e "${RED}✗ Failed to connect to Home Assistant${NC}"
        return 1
    fi
}

create_backup_dir() {
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "Would create backup directory: $BACKUP_DIR"
        return 0
    fi
    
    if [[ ! -d "$BACKUP_DIR" ]]; then
        mkdir -p "$BACKUP_DIR"
        echo -e "${GREEN}✓ Created backup directory: $BACKUP_DIR${NC}"
    else
        echo -e "${YELLOW}Backup directory already exists: $BACKUP_DIR${NC}"
    fi
}

api_call() {
    local endpoint="$1"
    local output_file="$2"
    local description="$3"
    
    echo -e "${BLUE}Getting $description...${NC}"
    
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "Would call: http://$HA_SERVER:$HA_PORT/api/$endpoint"
        echo "Would save to: $output_file"
        return 0
    fi
    
    local api_url="http://$HA_SERVER:$HA_PORT/api/$endpoint"
    
    if curl -s -H "Authorization: Bearer $HA_TOKEN" "$api_url" > "$output_file"; then
        echo -e "${GREEN}✓ Downloaded $description${NC}"
        return 0
    else
        echo -e "${RED}✗ Failed to download $description${NC}"
        return 1
    fi
}

get_config_info() {
    api_call "config" "$BACKUP_DIR/config_info.json" "configuration info"
}

get_entities() {
    api_call "states" "$BACKUP_DIR/entities.json" "all entities"
}

get_services() {
    api_call "services" "$BACKUP_DIR/services.json" "all services"
}

get_events() {
    api_call "events" "$BACKUP_DIR/events.json" "event types"
}

get_history() {
    local now=$(date -u +"%Y-%m-%dT%H:%M:%S")
    local yesterday=$(date -u -d "yesterday" +"%Y-%m-%dT%H:%M:%S")
    
    echo -e "${BLUE}Getting history (last 24 hours)...${NC}"
    
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "Would get history from $yesterday to $now"
        return 0
    fi
    
    local api_url="http://$HA_SERVER:$HA_PORT/api/history/period/$yesterday"
    
    if curl -s -H "Authorization: Bearer $HA_TOKEN" "$api_url" > "$BACKUP_DIR/history.json"; then
        echo -e "${GREEN}✓ Downloaded history${NC}"
        return 0
    else
        echo -e "${RED}✗ Failed to download history${NC}"
        return 1
    fi
}

get_logbook() {
    local now=$(date -u +"%Y-%m-%dT%H:%M:%S")
    local yesterday=$(date -u -d "yesterday" +"%Y-%m-%dT%H:%M:%S")
    
    echo -e "${BLUE}Getting logbook (last 24 hours)...${NC}"
    
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "Would get logbook from $yesterday to $now"
        return 0
    fi
    
    local api_url="http://$HA_SERVER:$HA_PORT/api/logbook/$yesterday"
    
    if curl -s -H "Authorization: Bearer $HA_TOKEN" "$api_url" > "$BACKUP_DIR/logbook.json"; then
        echo -e "${GREEN}✓ Downloaded logbook${NC}"
        return 0
    else
        echo -e "${RED}✗ Failed to download logbook${NC}"
        return 1
    fi
}

get_automations() {
    echo -e "${BLUE}Getting automations...${NC}"
    
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "Would get automations"
        return 0
    fi
    
    local api_url="http://$HA_SERVER:$HA_PORT/api/config/automation/config"
    
    if curl -s -H "Authorization: Bearer $HA_TOKEN" "$api_url" > "$BACKUP_DIR/automations_api.json"; then
        echo -e "${GREEN}✓ Downloaded automations${NC}"
        return 0
    else
        echo -e "${RED}✗ Failed to download automations${NC}"
        return 1
    fi
}

get_scripts() {
    echo -e "${BLUE}Getting scripts...${NC}"
    
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "Would get scripts"
        return 0
    fi
    
    local api_url="http://$HA_SERVER:$HA_PORT/api/config/script/config"
    
    if curl -s -H "Authorization: Bearer $HA_TOKEN" "$api_url" > "$BACKUP_DIR/scripts_api.json"; then
        echo -e "${GREEN}✓ Downloaded scripts${NC}"
        return 0
    else
        echo -e "${RED}✗ Failed to download scripts${NC}"
        return 1
    fi
}

get_scenes() {
    echo -e "${BLUE}Getting scenes...${NC}"
    
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "Would get scenes"
        return 0
    fi
    
    local api_url="http://$HA_SERVER:$HA_PORT/api/states"
    
    # Filter for scene entities
    if curl -s -H "Authorization: Bearer $HA_TOKEN" "$api_url" | jq '.[] | select(.entity_id | startswith("scene."))' > "$BACKUP_DIR/scenes_api.json"; then
        echo -e "${GREEN}✓ Downloaded scenes${NC}"
        return 0
    else
        echo -e "${RED}✗ Failed to download scenes${NC}"
        return 1
    fi
}

get_groups() {
    echo -e "${BLUE}Getting groups...${NC}"
    
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "Would get groups"
        return 0
    fi
    
    local api_url="http://$HA_SERVER:$HA_PORT/api/states"
    
    # Filter for group entities
    if curl -s -H "Authorization: Bearer $HA_TOKEN" "$api_url" | jq '.[] | select(.entity_id | startswith("group."))' > "$BACKUP_DIR/groups_api.json"; then
        echo -e "${GREEN}✓ Downloaded groups${NC}"
        return 0
    else
        echo -e "${RED}✗ Failed to download groups${NC}"
        return 1
    fi
}

convert_json_to_yaml() {
    echo -e "${BLUE}Converting JSON data to YAML format...${NC}"
    
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "Would convert JSON files to YAML"
        return 0
    fi
    
    # Convert automations
    if [[ -f "$BACKUP_DIR/automations_api.json" ]]; then
        if command -v yq >/dev/null 2>&1; then
            yq eval -P "$BACKUP_DIR/automations_api.json" > "$BACKUP_DIR/automations_from_api.yaml" 2>/dev/null || true
            echo -e "${GREEN}✓ Converted automations to YAML${NC}"
        else
            echo -e "${YELLOW}⚠ yq not found, skipping YAML conversion${NC}"
        fi
    fi
    
    # Convert scripts
    if [[ -f "$BACKUP_DIR/scripts_api.json" ]]; then
        if command -v yq >/dev/null 2>&1; then
            yq eval -P "$BACKUP_DIR/scripts_api.json" > "$BACKUP_DIR/scripts_from_api.yaml" 2>/dev/null || true
            echo -e "${GREEN}✓ Converted scripts to YAML${NC}"
        fi
    fi
}

generate_summary() {
    echo -e "${BLUE}Generating configuration summary...${NC}"
    
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "Would generate summary"
        return 0
    fi
    
    cat > "$BACKUP_DIR/API_EXPORT_SUMMARY.md" << EOF
# Home Assistant API Export Summary

## Export Details
- **Server**: $HA_SERVER:$HA_PORT
- **Export Date**: $(date)
- **Export Method**: Home Assistant API

## Files Exported
EOF

    # List all exported files
    for file in "$BACKUP_DIR"/*.json "$BACKUP_DIR"/*.yaml; do
        if [[ -f "$file" ]]; then
            local basename=$(basename "$file")
            local size=$(wc -c < "$file")
            echo "- **$basename**: $size bytes" >> "$BACKUP_DIR/API_EXPORT_SUMMARY.md"
        fi
    done
    
    cat >> "$BACKUP_DIR/API_EXPORT_SUMMARY.md" << EOF

## Configuration Analysis
Run the following to analyze your exported configuration:

\`\`\`bash
# Analyze the exported data
./bin/ha-analyze --backup-dir $BACKUP_DIR

# Compare with dotfiles
./bin/ha-analyze
\`\`\`

## Next Steps
1. Review the exported JSON files
2. Convert relevant data to YAML format
3. Merge with your dotfiles configuration
4. Test and deploy updated configuration

## Notes
- JSON files contain raw API data
- YAML files are converted versions (if yq is available)
- Some configuration may need manual conversion
- Secrets are not included in API exports
EOF

    echo -e "${GREEN}✓ Generated summary: $BACKUP_DIR/API_EXPORT_SUMMARY.md${NC}"
}

main() {
    DRY_RUN="false"
    
    # Parse command line arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --token)
                HA_TOKEN="$2"
                shift 2
                ;;
            --backup-dir)
                BACKUP_DIR="$2"
                shift 2
                ;;
            --dry-run)
                DRY_RUN="true"
                shift
                ;;
            --help)
                usage
                exit 0
                ;;
            *)
                echo "Unknown option: $1"
                usage
                exit 1
                ;;
        esac
    done
    
    echo -e "${GREEN}Home Assistant API Configuration Puller${NC}"
    echo "Server: http://$HA_SERVER:$HA_PORT"
    echo "Backup Dir: $BACKUP_DIR"
    echo ""
    
    # Check if token is provided
    check_token
    
    # Create backup directory
    create_backup_dir
    
    # Test connection
    if ! test_connection; then
        echo -e "${RED}Failed to connect to Home Assistant${NC}"
        echo "Please check:"
        echo "1. Home Assistant is running at $HA_SERVER:$HA_PORT"
        echo "2. Your API token is correct"
        echo "3. Your network connection is working"
        exit 1
    fi
    
    echo ""
    
    # Download configuration data
    local failed_downloads=()
    
    if ! get_config_info; then
        failed_downloads+=("config_info")
    fi
    
    if ! get_entities; then
        failed_downloads+=("entities")
    fi
    
    if ! get_services; then
        failed_downloads+=("services")
    fi
    
    if ! get_events; then
        failed_downloads+=("events")
    fi
    
    if ! get_automations; then
        failed_downloads+=("automations")
    fi
    
    if ! get_scripts; then
        failed_downloads+=("scripts")
    fi
    
    if ! get_scenes; then
        failed_downloads+=("scenes")
    fi
    
    if ! get_groups; then
        failed_downloads+=("groups")
    fi
    
    # Optional: Get history and logbook (can be large)
    echo -e "${YELLOW}Skip history/logbook? (y/N): ${NC}"
    read -r skip_history
    if [[ "$skip_history" != "y" && "$skip_history" != "Y" ]]; then
        get_history
        get_logbook
    fi
    
    # Convert JSON to YAML
    convert_json_to_yaml
    
    # Generate summary
    generate_summary
    
    echo ""
    echo -e "${GREEN}API Export Summary:${NC}"
    
    if [[ ${#failed_downloads[@]} -eq 0 ]]; then
        echo -e "${GREEN}✓ Successfully downloaded all available data${NC}"
    else
        echo -e "${YELLOW}⚠ Some downloads failed: ${failed_downloads[*]}${NC}"
    fi
    
    echo ""
    echo -e "${BLUE}Next steps:${NC}"
    echo "1. Review exported files in: $BACKUP_DIR"
    echo "2. Run: ./bin/ha-analyze --backup-dir $BACKUP_DIR"
    echo "3. Compare with dotfiles and merge as needed"
    echo "4. Check: $BACKUP_DIR/API_EXPORT_SUMMARY.md for details"
}

main "$@"












