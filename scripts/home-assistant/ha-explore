#!/usr/bin/env bash
# Home Assistant Interface Explorer
# Helps you find the token section in your Home Assistant interface

set -euo pipefail

HA_SERVER="192.168.0.105"
HA_PORT="8123"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

usage() {
    echo "Usage: $0 [OPTIONS]"
    echo "Options:"
    echo "  --open-all        Open all relevant pages in browser"
    echo "  --help           Show this help message"
    echo ""
    echo "This script helps you explore your Home Assistant interface"
    echo "to find where to create API tokens."
}

open_url() {
    local url="$1"
    local description="$2"
    
    echo -e "${BLUE}Opening: $description${NC}"
    echo "URL: $url"
    
    if command -v open >/dev/null 2>&1; then
        open "$url"
        echo -e "${GREEN}✓ Opened in browser${NC}"
    elif command -v xdg-open >/dev/null 2>&1; then
        xdg-open "$url"
        echo -e "${GREEN}✓ Opened in browser${NC}"
    else
        echo -e "${YELLOW}⚠ Could not open browser automatically${NC}"
        echo "Please open: $url"
    fi
    
    echo ""
}

explore_interface() {
    echo -e "${GREEN}Home Assistant Interface Explorer${NC}"
    echo "Server: http://$HA_SERVER:$HA_PORT"
    echo ""
    
    echo -e "${BLUE}Let's explore your Home Assistant interface to find the token section:${NC}"
    echo ""
    
    # Main pages to check
    local pages=(
        "http://$HA_SERVER:$HA_PORT/profile:Profile Page"
        "http://$HA_SERVER:$HA_PORT/config:Settings/Configuration"
        "http://$HA_SERVER:$HA_PORT/developer-tools:Developer Tools"
        "http://$HA_SERVER:$HA_PORT/supervisor:Supervisor (if using Home Assistant OS)"
    )
    
    echo -e "${YELLOW}We'll check these pages one by one:${NC}"
    echo ""
    
    for page_info in "${pages[@]}"; do
        local url="${page_info%%:*}"
        local description="${page_info#*:}"
        
        echo -e "${BLUE}=== $description ===${NC}"
        echo "URL: $url"
        echo ""
        echo "Look for any of these terms:"
        echo "• 'Long-lived access tokens'"
        echo "• 'Personal access tokens'"
        echo "• 'API tokens'"
        echo "• 'Create token'"
        echo "• 'Add token'"
        echo ""
        
        if [[ "$OPEN_ALL" == "true" ]]; then
            open_url "$url" "$description"
        else
            echo -e "${YELLOW}Press Enter to open this page, or 's' to skip: ${NC}"
            read -r choice
            
            if [[ "$choice" != "s" && "$choice" != "S" ]]; then
                open_url "$url" "$description"
            fi
        fi
        
        echo -e "${YELLOW}Did you find a token section on this page? (y/n): ${NC}"
        read -r found_token
        
        if [[ "$found_token" == "y" || "$found_token" == "Y" ]]; then
            echo -e "${GREEN}Great! You found the token section.${NC}"
            echo ""
            echo -e "${BLUE}Next steps:${NC}"
            echo "1. Create a new token"
            echo "2. Give it a name (e.g., 'Dotfiles Integration')"
            echo "3. Copy the token"
            echo "4. Run: ./bin/ha-pull-api-v2 --token YOUR_TOKEN"
            echo ""
            return 0
        fi
        
        echo ""
    done
    
    echo -e "${RED}We couldn't find the token section in the main pages.${NC}"
    echo ""
    echo -e "${YELLOW}Alternative approaches:${NC}"
    echo "1. Check if you're using Home Assistant Core vs Home Assistant OS"
    echo "2. Look for 'Settings' or 'Configuration' in the sidebar"
    echo "3. Check if you need to enable 'Advanced Mode' first"
    echo "4. Try the manual export method: ./bin/ha-export-guide"
    echo ""
}

check_ha_version() {
    echo -e "${BLUE}Let's check your Home Assistant version:${NC}"
    echo ""
    
    local version_url="http://$HA_SERVER:$HA_PORT/api/"
    
    echo "Checking Home Assistant API..."
    if curl -s "$version_url" >/dev/null 2>&1; then
        echo -e "${GREEN}✓ Home Assistant is running${NC}"
        
        # Try to get version info
        local info_url="http://$HA_SERVER:$HA_PORT/api/config"
        if response=$(curl -s "$info_url" 2>/dev/null); then
            echo "API is accessible (no auth required for basic info)"
        else
            echo "API requires authentication"
        fi
    else
        echo -e "${RED}✗ Cannot reach Home Assistant${NC}"
        echo "Please check:"
        echo "1. Home Assistant is running"
        echo "2. The server address is correct: $HA_SERVER:$HA_PORT"
        echo "3. Your network connection"
    fi
    
    echo ""
}

main() {
    OPEN_ALL="false"
    
    # Parse command line arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --open-all)
                OPEN_ALL="true"
                shift
                ;;
            --help)
                usage
                exit 0
                ;;
            *)
                echo "Unknown option: $1"
                usage
                exit 1
                ;;
        esac
    done
    
    echo -e "${GREEN}Home Assistant Interface Explorer${NC}"
    echo "Server: http://$HA_SERVER:$HA_PORT"
    echo ""
    
    # Check if HA is running
    check_ha_version
    
    # Explore the interface
    explore_interface
    
    echo -e "${BLUE}If you still can't find the token section:${NC}"
    echo "1. Try the manual export method: ./bin/ha-export-guide"
    echo "2. Check Home Assistant documentation for your specific version"
    echo "3. Look for 'Advanced Mode' in settings and enable it"
    echo "4. Try accessing the API directly to see what's available"
}

main "$@"












