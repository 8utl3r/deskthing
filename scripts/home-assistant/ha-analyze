#!/usr/bin/env bash
# Home Assistant Configuration Analyzer
# Analyzes exported Home Assistant configuration and compares with dotfiles

set -euo pipefail

BACKUP_DIR="${BACKUP_DIR:-./homeassistant/backup}"
DOTFILES_DIR="./homeassistant"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

usage() {
    echo "Usage: $0 [OPTIONS]"
    echo "Options:"
    echo "  --backup-dir DIR   Directory containing exported configs (default: ./homeassistant/backup)"
    echo "  --help             Show this help message"
    echo ""
    echo "This script analyzes your exported Home Assistant configuration"
    echo "and compares it with your dotfiles setup."
}

analyze_file() {
    local file="$1"
    local basename=$(basename "$file")
    
    echo -e "${BLUE}=== Analyzing $basename ===${NC}"
    
    if [[ ! -f "$file" ]]; then
        echo -e "${RED}✗ File not found: $file${NC}"
        return 1
    fi
    
    # Get file size
    local size=$(wc -c < "$file")
    echo -e "${GREEN}File size: $size bytes${NC}"
    
    # Count lines
    local lines=$(wc -l < "$file")
    echo -e "${GREEN}Lines: $lines${NC}"
    
    # Check for common patterns
    if grep -q "automation:" "$file"; then
        local automation_count=$(grep -c "^- id:" "$file" || echo "0")
        echo -e "${GREEN}Automations: $automation_count${NC}"
    fi
    
    if grep -q "script:" "$file"; then
        local script_count=$(grep -c "^[a-zA-Z_][a-zA-Z0-9_]*:" "$file" || echo "0")
        echo -e "${GREEN}Scripts: $script_count${NC}"
    fi
    
    if grep -q "webostv:" "$file"; then
        echo -e "${GREEN}✓ Contains LG webOS TV integration${NC}"
    fi
    
    if grep -q "ios:" "$file"; then
        echo -e "${GREEN}✓ Contains iOS/macOS integration${NC}"
    fi
    
    if grep -q "!secret" "$file"; then
        local secret_count=$(grep -c "!secret" "$file")
        echo -e "${YELLOW}⚠ Contains $secret_count secret references${NC}"
    fi
    
    echo ""
}

compare_with_dotfiles() {
    echo -e "${BLUE}=== Comparing with Dotfiles ===${NC}"
    
    local files=("configuration.yaml" "automations.yaml" "scripts.yaml" "groups.yaml" "scenes.yaml")
    
    for file in "${files[@]}"; do
        local backup_file="$BACKUP_DIR/$file"
        local dotfiles_file="$DOTFILES_DIR/$file"
        
        echo -e "${BLUE}Comparing $file:${NC}"
        
        if [[ -f "$backup_file" && -f "$dotfiles_file" ]]; then
            if diff -q "$backup_file" "$dotfiles_file" >/dev/null 2>&1; then
                echo -e "${GREEN}✓ Files are identical${NC}"
            else
                echo -e "${YELLOW}⚠ Files differ${NC}"
                echo "Backup file: $backup_file"
                echo "Dotfiles file: $dotfiles_file"
            fi
        elif [[ -f "$backup_file" ]]; then
            echo -e "${YELLOW}⚠ Backup file exists but dotfiles file missing${NC}"
            echo "Consider copying: $backup_file -> $dotfiles_file"
        elif [[ -f "$dotfiles_file" ]]; then
            echo -e "${YELLOW}⚠ Dotfiles file exists but backup file missing${NC}"
            echo "Dotfiles file: $dotfiles_file"
        else
            echo -e "${RED}✗ Neither file exists${NC}"
        fi
        echo ""
    done
}

generate_merge_plan() {
    echo -e "${BLUE}=== Merge Plan ===${NC}"
    
    local files=("configuration.yaml" "automations.yaml" "scripts.yaml" "groups.yaml" "scenes.yaml")
    
    for file in "${files[@]}"; do
        local backup_file="$BACKUP_DIR/$file"
        local dotfiles_file="$DOTFILES_DIR/$file"
        
        if [[ -f "$backup_file" ]]; then
            echo -e "${GREEN}✓ $file exists in backup${NC}"
            
            if [[ -f "$dotfiles_file" ]]; then
                echo -e "${YELLOW}  → Compare and merge with dotfiles version${NC}"
            else
                echo -e "${YELLOW}  → Copy to dotfiles: cp $backup_file $dotfiles_file${NC}"
            fi
        else
            echo -e "${RED}✗ $file missing from backup${NC}"
        fi
    done
    
    echo ""
    echo -e "${BLUE}Recommended Actions:${NC}"
    echo "1. Review differences between backup and dotfiles"
    echo "2. Merge configurations carefully"
    echo "3. Test merged configuration"
    echo "4. Update secrets.yaml with actual values"
    echo "5. Deploy using: ./bin/ha-sync"
}

main() {
    # Parse command line arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --backup-dir)
                BACKUP_DIR="$2"
                shift 2
                ;;
            --help)
                usage
                exit 0
                ;;
            *)
                echo "Unknown option: $1"
                usage
                exit 1
                ;;
        esac
    done
    
    echo -e "${GREEN}Home Assistant Configuration Analyzer${NC}"
    echo "Backup Dir: $BACKUP_DIR"
    echo "Dotfiles Dir: $DOTFILES_DIR"
    echo ""
    
    if [[ ! -d "$BACKUP_DIR" ]]; then
        echo -e "${RED}Error: Backup directory not found: $BACKUP_DIR${NC}"
        echo "Run ./bin/ha-export-guide first to export your configuration"
        exit 1
    fi
    
    # Analyze each file
    local files=("configuration.yaml" "automations.yaml" "scripts.yaml" "groups.yaml" "scenes.yaml" "secrets.yaml" "customize.yaml")
    
    for file in "${files[@]}"; do
        analyze_file "$BACKUP_DIR/$file"
    done
    
    # Compare with dotfiles
    compare_with_dotfiles
    
    # Generate merge plan
    generate_merge_plan
    
    echo -e "${GREEN}Analysis complete!${NC}"
    echo "Review the output above and follow the recommended actions."
}

main "$@"












