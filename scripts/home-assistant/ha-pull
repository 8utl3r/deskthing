#!/usr/bin/env bash
# Home Assistant Configuration Pull Script
# Downloads existing configuration from remote Home Assistant server

set -euo pipefail

HA_SERVER="192.168.0.105"
HA_PORT="8123"
HA_USER="${HA_USER:-homeassistant}"
HA_CONFIG_DIR="${HA_CONFIG_DIR:-/config}"
BACKUP_DIR="${BACKUP_DIR:-./homeassistant/backup}"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

usage() {
    echo "Usage: $0 [OPTIONS]"
    echo "Options:"
    echo "  --backup-dir DIR    Directory to store downloaded configs (default: ./homeassistant/backup)"
    echo "  --dry-run          Show what would be downloaded without actually downloading"
    echo "  --help             Show this help message"
    echo ""
    echo "Environment variables:"
    echo "  HA_USER            Home Assistant server username (default: homeassistant)"
    echo "  HA_CONFIG_DIR      Home Assistant config directory (default: /config)"
    echo "  BACKUP_DIR         Local backup directory (default: ./homeassistant/backup)"
}

download_file() {
    local remote_file="$1"
    local local_file="$2"
    local basename=$(basename "$remote_file")
    
    echo -e "${BLUE}Downloading $basename...${NC}"
    
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "Would download: $HA_USER@$HA_SERVER:$remote_file -> $local_file"
        return 0
    fi
    
    # Use scp to download file from remote server
    if scp "$HA_USER@$HA_SERVER:$remote_file" "$local_file"; then
        echo -e "${GREEN}✓ Downloaded $basename${NC}"
        return 0
    else
        echo -e "${RED}✗ Failed to download $basename${NC}"
        return 1
    fi
}

list_remote_files() {
    echo -e "${BLUE}Listing files on Home Assistant server...${NC}"
    
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "Would list files in: $HA_USER@$HA_SERVER:$HA_CONFIG_DIR"
        return 0
    fi
    
    # Use ssh to list files on remote server
    if ssh "$HA_USER@$HA_SERVER" "ls -la $HA_CONFIG_DIR/*.yaml 2>/dev/null || echo 'No YAML files found'"; then
        echo -e "${GREEN}✓ Listed remote files${NC}"
        return 0
    else
        echo -e "${RED}✗ Failed to list remote files${NC}"
        return 1
    fi
}

create_backup_dir() {
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "Would create backup directory: $BACKUP_DIR"
        return 0
    fi
    
    if [[ ! -d "$BACKUP_DIR" ]]; then
        mkdir -p "$BACKUP_DIR"
        echo -e "${GREEN}✓ Created backup directory: $BACKUP_DIR${NC}"
    else
        echo -e "${YELLOW}Backup directory already exists: $BACKUP_DIR${NC}"
    fi
}

main() {
    DRY_RUN="false"
    
    # Parse command line arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --backup-dir)
                BACKUP_DIR="$2"
                shift 2
                ;;
            --dry-run)
                DRY_RUN="true"
                shift
                ;;
            --help)
                usage
                exit 0
                ;;
            *)
                echo "Unknown option: $1"
                usage
                exit 1
                ;;
        esac
    done
    
    echo -e "${GREEN}Home Assistant Configuration Pull${NC}"
    echo "Server: $HA_SERVER:$HA_PORT"
    echo "User: $HA_USER"
    echo "Config Dir: $HA_CONFIG_DIR"
    echo "Backup Dir: $BACKUP_DIR"
    echo ""
    
    # Create backup directory
    create_backup_dir
    
    # List remote files first
    list_remote_files
    echo ""
    
    # Files to download
    files=(
        "configuration.yaml"
        "automations.yaml"
        "scripts.yaml"
        "groups.yaml"
        "scenes.yaml"
        "secrets.yaml"
        "customize.yaml"
        "customize.yaml"
        "ui-lovelace.yaml"
        "themes.yaml"
        "known_devices.yaml"
        "homekit.yaml"
        "zha.yaml"
        "zwave.yaml"
    )
    
    failed_files=()
    downloaded_files=()
    
    for file in "${files[@]}"; do
        remote_file="$HA_CONFIG_DIR/$file"
        local_file="$BACKUP_DIR/$file"
        
        if download_file "$remote_file" "$local_file"; then
            downloaded_files+=("$file")
        else
            failed_files+=("$file")
        fi
    done
    
    echo ""
    echo -e "${GREEN}Download Summary:${NC}"
    
    if [[ ${#downloaded_files[@]} -gt 0 ]]; then
        echo -e "${GREEN}✓ Downloaded: ${downloaded_files[*]}${NC}"
    fi
    
    if [[ ${#failed_files[@]} -gt 0 ]]; then
        echo -e "${YELLOW}⚠ Failed to download: ${failed_files[*]}${NC}"
        echo "Note: Some files may not exist on the server, which is normal"
    fi
    
    if [[ "$DRY_RUN" == "false" ]]; then
        echo ""
        echo -e "${BLUE}Next steps:${NC}"
        echo "1. Review downloaded files in: $BACKUP_DIR"
        echo "2. Compare with dotfiles configuration"
        echo "3. Merge any missing configurations"
        echo "4. Update dotfiles as needed"
    fi
}

main "$@"












