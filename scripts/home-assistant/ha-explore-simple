#!/usr/bin/env bash
# Home Assistant Configuration Explorer
# Explores your Home Assistant setup without requiring authentication

set -euo pipefail

HA_SERVER="192.168.0.105"
HA_PORT="8123"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

usage() {
    echo "Usage: $0 [OPTIONS]"
    echo "Options:"
    echo "  --check-api       Check what API endpoints are available"
    echo "  --open-pages      Open relevant pages in browser"
    echo "  --help           Show this help message"
    echo ""
    echo "This script explores your Home Assistant setup to help you"
    echo "find the best way to export your configuration."
}

check_api_endpoints() {
    echo -e "${GREEN}Home Assistant API Explorer${NC}"
    echo "Server: http://$HA_SERVER:$HA_PORT"
    echo ""
    
    echo -e "${BLUE}Checking available API endpoints...${NC}"
    
    # Check basic API
    local api_url="http://$HA_SERVER:$HA_PORT/api/"
    echo "Testing: $api_url"
    
    if response=$(curl -s -w "%{http_code}" "$api_url" 2>/dev/null); then
        local http_code="${response: -3}"
        local body="${response%???}"
        
        if [[ "$http_code" == "200" ]]; then
            echo -e "${GREEN}‚úď API is accessible${NC}"
            echo "Response: $body"
        elif [[ "$http_code" == "401" ]]; then
            echo -e "${YELLOW}‚ö† API requires authentication${NC}"
            echo "This means you need a token to access the API"
        else
            echo -e "${RED}‚úó API returned HTTP $http_code${NC}"
        fi
    else
        echo -e "${RED}‚úó Cannot reach API${NC}"
    fi
    
    echo ""
    
    # Check if we can access the web interface
    local web_url="http://$HA_SERVER:$HA_PORT"
    echo "Testing web interface: $web_url"
    
    if curl -s -I "$web_url" | grep -q "200 OK"; then
        echo -e "${GREEN}‚úď Web interface is accessible${NC}"
    else
        echo -e "${RED}‚úó Cannot reach web interface${NC}"
    fi
    
    echo ""
}

open_relevant_pages() {
    echo -e "${BLUE}Opening relevant pages in your browser...${NC}"
    echo ""
    
    local pages=(
        "http://$HA_SERVER:$HA_PORT:Home Assistant Main Page"
        "http://$HA_SERVER:$HA_PORT/profile:Profile Page"
        "http://$HA_SERVER:$HA_PORT/config:Settings/Configuration"
        "http://$HA_SERVER:$HA_PORT/developer-tools:Developer Tools"
    )
    
    for page_info in "${pages[@]}"; do
        local url="${page_info%%:*}"
        local description="${page_info#*:}"
        
        echo -e "${BLUE}Opening: $description${NC}"
        echo "URL: $url"
        
        if command -v open >/dev/null 2>&1; then
            open "$url"
        elif command -v xdg-open >/dev/null 2>&1; then
            xdg-open "$url"
        else
            echo -e "${YELLOW}‚ö† Could not open browser automatically${NC}"
            echo "Please open: $url"
        fi
        
        echo ""
    done
}

show_alternative_methods() {
    echo -e "${GREEN}Alternative Methods to Export Configuration${NC}"
    echo ""
    
    echo -e "${BLUE}Method 1: Manual Export (Recommended)${NC}"
    echo "Since you can't find the token section, let's use the manual method:"
    echo ""
    echo "1. Go to http://$HA_SERVER:$HA_PORT"
    echo "2. Install the 'File editor' add-on if not already installed"
    echo "3. Go to Settings ‚Üí Add-ons ‚Üí File editor"
    echo "4. Open the file editor and navigate to your config files"
    echo "5. Copy the contents of each YAML file"
    echo "6. Save them locally in ./homeassistant/backup/"
    echo ""
    echo "Run: ./bin/ha-export-guide for detailed instructions"
    echo ""
    
    echo -e "${BLUE}Method 2: Backup Download${NC}"
    echo "1. Go to http://$HA_SERVER:$HA_PORT/config"
    echo "2. Look for 'Server Controls' or 'Backup'"
    echo "3. Click 'Download backup'"
    echo "4. Extract the backup and copy config files"
    echo ""
    
    echo -e "${BLUE}Method 3: Find Token Section${NC}"
    echo "The token section might be in different locations:"
    echo "‚ÄĘ Profile page (bottom)"
    echo "‚ÄĘ Settings ‚Üí Personal access tokens"
    echo "‚ÄĘ Developer tools ‚Üí API"
    echo "‚ÄĘ Advanced mode might need to be enabled first"
    echo ""
    
    echo -e "${BLUE}Method 4: Direct File Access${NC}"
    echo "If you have SSH access to your Home Assistant server:"
    echo "1. SSH into your server"
    echo "2. Navigate to /config directory"
    echo "3. Copy the YAML files"
    echo ""
}

check_ha_type() {
    echo -e "${BLUE}Detecting Home Assistant type...${NC}"
    
    # Check if it's Home Assistant OS (Supervisor)
    local supervisor_url="http://$HA_SERVER:$HA_PORT/supervisor"
    if curl -s -I "$supervisor_url" | grep -q "200 OK"; then
        echo -e "${GREEN}‚úď Home Assistant OS detected (has Supervisor)${NC}"
        echo "Token section should be in Settings ‚Üí Personal access tokens"
    else
        echo -e "${YELLOW}‚ö† Home Assistant Core detected${NC}"
        echo "Token section should be in Profile page"
    fi
    
    echo ""
}

main() {
    local check_api=false
    local open_pages=false
    
    # Parse command line arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --check-api)
                check_api=true
                shift
                ;;
            --open-pages)
                open_pages=true
                shift
                ;;
            --help)
                usage
                exit 0
                ;;
            *)
                echo "Unknown option: $1"
                usage
                exit 1
                ;;
        esac
    done
    
    echo -e "${GREEN}Home Assistant Configuration Explorer${NC}"
    echo "Server: http://$HA_SERVER:$HA_PORT"
    echo ""
    
    # Check API endpoints
    if [[ "$check_api" == "true" ]]; then
        check_api_endpoints
    fi
    
    # Check HA type
    check_ha_type
    
    # Open pages
    if [[ "$open_pages" == "true" ]]; then
        open_relevant_pages
    fi
    
    # Show alternative methods
    show_alternative_methods
    
    echo -e "${BLUE}Recommended Next Steps:${NC}"
    echo "1. Run: ./bin/ha-explore to systematically check each page"
    echo "2. Or run: ./bin/ha-export-guide for manual export instructions"
    echo "3. Or try: ./bin/ha-explore --open-all to open all pages at once"
}

main "$@"












