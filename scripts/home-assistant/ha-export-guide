#!/usr/bin/env bash
# Home Assistant Configuration Export Helper
# Guides you through exporting your existing Home Assistant configuration

set -euo pipefail

HA_SERVER="192.168.0.105"
HA_PORT="8123"
BACKUP_DIR="${BACKUP_DIR:-./homeassistant/backup}"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

usage() {
    echo "Usage: $0 [OPTIONS]"
    echo "Options:"
    echo "  --backup-dir DIR   Directory to store exported configs (default: ./homeassistant/backup)"
    echo "  --help             Show this help message"
    echo ""
    echo "This script will guide you through exporting your Home Assistant configuration"
    echo "manually from the web interface."
}

create_backup_dir() {
    if [[ ! -d "$BACKUP_DIR" ]]; then
        mkdir -p "$BACKUP_DIR"
        echo -e "${GREEN}✓ Created backup directory: $BACKUP_DIR${NC}"
    else
        echo -e "${YELLOW}Backup directory already exists: $BACKUP_DIR${NC}"
    fi
}

show_export_instructions() {
    echo -e "${GREEN}Home Assistant Configuration Export Guide${NC}"
    echo ""
    echo -e "${BLUE}Step 1: Access Home Assistant${NC}"
    echo "Open your browser and go to: http://$HA_SERVER:$HA_PORT"
    echo ""
    
    echo -e "${BLUE}Step 2: Export Configuration${NC}"
    echo "There are several ways to export your configuration:"
    echo ""
    
    echo -e "${YELLOW}Method 1: File Editor (Recommended)${NC}"
    echo "1. Go to Settings → Add-ons → File editor"
    echo "2. If not installed, install the 'File editor' add-on"
    echo "3. Open the file editor"
    echo "4. Navigate to your config files and copy their contents"
    echo "5. Save them locally in: $BACKUP_DIR"
    echo ""
    
    echo -e "${YELLOW}Method 2: Configuration → Server Controls${NC}"
    echo "1. Go to Settings → System → Server Controls"
    echo "2. Click 'Download backup' to get a full backup"
    echo "3. Extract the backup and copy config files to: $BACKUP_DIR"
    echo ""
    
    echo -e "${YELLOW}Method 3: Terminal/SSH (if available)${NC}"
    echo "1. Access your Home Assistant server via SSH or terminal"
    echo "2. Navigate to the config directory (usually /config)"
    echo "3. Copy the YAML files to your local machine"
    echo ""
    
    echo -e "${BLUE}Step 3: Files to Export${NC}"
    echo "Export these key configuration files:"
    echo "• configuration.yaml (main configuration)"
    echo "• automations.yaml (automation rules)"
    echo "• scripts.yaml (reusable scripts)"
    echo "• groups.yaml (device grouping)"
    echo "• scenes.yaml (predefined scenes)"
    echo "• secrets.yaml (sensitive data - be careful!)"
    echo "• customize.yaml (customizations)"
    echo "• ui-lovelace.yaml (dashboard configuration)"
    echo ""
    
    echo -e "${BLUE}Step 4: After Export${NC}"
    echo "Once you've exported the files:"
    echo "1. Place them in: $BACKUP_DIR"
    echo "2. Run: ./bin/ha-analyze to analyze your configuration"
    echo "3. Compare with dotfiles and merge as needed"
}

create_template_files() {
    echo -e "${BLUE}Creating template files for manual export...${NC}"
    
    # Create a template for what to export
    cat > "$BACKUP_DIR/EXPORT_CHECKLIST.md" << 'EOF'
# Home Assistant Configuration Export Checklist

## Files to Export
- [ ] configuration.yaml
- [ ] automations.yaml
- [ ] scripts.yaml
- [ ] groups.yaml
- [ ] scenes.yaml
- [ ] secrets.yaml (⚠️ Contains sensitive data)
- [ ] customize.yaml
- [ ] ui-lovelace.yaml
- [ ] themes.yaml (if you have custom themes)
- [ ] known_devices.yaml (if you want device history)

## Export Methods

### Method 1: File Editor (Easiest)
1. Install File Editor add-on if not already installed
2. Go to Settings → Add-ons → File editor
3. Open each file and copy contents
4. Save locally with same filename

### Method 2: Backup Download
1. Go to Settings → System → Server Controls
2. Click "Download backup"
3. Extract the backup archive
4. Copy config files from the extracted folder

### Method 3: SSH/Terminal (Advanced)
1. Access server via SSH or terminal
2. Navigate to /config directory
3. Copy files using scp or similar

## After Export
1. Place all files in the backup directory
2. Run `./bin/ha-analyze` to analyze your configuration
3. Compare with dotfiles and merge as needed
4. Update dotfiles with your existing setup

## Security Note
- Never commit secrets.yaml to git
- Be careful with API keys and passwords
- Use secrets.yaml.template for non-sensitive defaults
EOF

    echo -e "${GREEN}✓ Created export checklist: $BACKUP_DIR/EXPORT_CHECKLIST.md${NC}"
}

main() {
    # Parse command line arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --backup-dir)
                BACKUP_DIR="$2"
                shift 2
                ;;
            --help)
                usage
                exit 0
                ;;
            *)
                echo "Unknown option: $1"
                usage
                exit 1
                ;;
        esac
    done
    
    echo -e "${GREEN}Home Assistant Configuration Export Helper${NC}"
    echo "Server: http://$HA_SERVER:$HA_PORT"
    echo "Backup Dir: $BACKUP_DIR"
    echo ""
    
    # Create backup directory
    create_backup_dir
    
    # Show export instructions
    show_export_instructions
    
    # Create template files
    create_template_files
    
    echo ""
    echo -e "${GREEN}Ready to export your configuration!${NC}"
    echo "Follow the instructions above to export your files."
    echo "Then run: ./bin/ha-analyze to analyze your configuration"
}

main "$@"












