#!/usr/bin/env bash
# Home Assistant API Token Helper
# Helps you get your Home Assistant API token

set -euo pipefail

HA_SERVER="192.168.0.105"
HA_PORT="8123"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

usage() {
    echo "Usage: $0 [OPTIONS]"
    echo "Options:"
    echo "  --open-browser    Open the profile page in your browser"
    echo "  --help           Show this help message"
    echo ""
    echo "This script helps you get your Home Assistant API token."
}

open_browser() {
    local url="http://$HA_SERVER:$HA_PORT/profile"
    
    echo -e "${BLUE}Opening Home Assistant profile page...${NC}"
    echo "URL: $url"
    
    if command -v open >/dev/null 2>&1; then
        open "$url"
        echo -e "${GREEN}✓ Opened in browser${NC}"
    elif command -v xdg-open >/dev/null 2>&1; then
        xdg-open "$url"
        echo -e "${GREEN}✓ Opened in browser${NC}"
    else
        echo -e "${YELLOW}⚠ Could not open browser automatically${NC}"
        echo "Please open: $url"
    fi
}

show_instructions() {
    echo -e "${GREEN}Home Assistant API Token Instructions${NC}"
    echo ""
    echo -e "${BLUE}Step 1: Access Your Profile${NC}"
    echo "Go to: http://$HA_SERVER:$HA_PORT/profile"
    echo ""
    
    echo -e "${BLUE}Step 2: Find the Token Section${NC}"
    echo "The token section might be in different locations depending on your HA version:"
    echo ""
    echo -e "${YELLOW}Option A: Profile Page${NC}"
    echo "1. Go to http://$HA_SERVER:$HA_PORT/profile"
    echo "2. Scroll down to find 'Long-lived access tokens' or 'Personal access tokens'"
    echo "3. Click 'Create token' or 'Add token'"
    echo ""
    echo -e "${YELLOW}Option B: Settings Page${NC}"
    echo "1. Go to http://$HA_SERVER:$HA_PORT/config"
    echo "2. Look for 'Personal access tokens' or 'API tokens'"
    echo "3. Click 'Create token'"
    echo ""
    echo -e "${YELLOW}Option C: Developer Tools${NC}"
    echo "1. Go to http://$HA_SERVER:$HA_PORT/developer-tools"
    echo "2. Look for 'API' or 'Tokens' section"
    echo "3. Create a new token"
    echo ""
    
    echo -e "${BLUE}Step 3: Create the Token${NC}"
    echo "1. Give it a name (e.g., 'Dotfiles Integration')"
    echo "2. Click 'Create' or 'OK'"
    echo "3. Copy the token (it will look like: eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...)"
    echo ""
    
    echo -e "${BLUE}Step 3: Use the Token${NC}"
    echo "You can use the token in several ways:"
    echo ""
    echo -e "${YELLOW}Option 1: Environment Variable${NC}"
    echo "export HA_TOKEN=your_token_here"
    echo "./bin/ha-pull-api-v2"
    echo ""
    echo -e "${YELLOW}Option 2: Command Line${NC}"
    echo "./bin/ha-pull-api-v2 --token your_token_here"
    echo ""
    echo -e "${YELLOW}Option 3: Save to File${NC}"
    echo "echo 'your_token_here' > ~/.homeassistant_token"
    echo "export HA_TOKEN=\$(cat ~/.homeassistant_token)"
    echo ""
    
    echo -e "${BLUE}Step 4: Test the Token${NC}"
    echo "Run: ./bin/ha-pull-api-v2 --dry-run --token your_token_here"
    echo ""
    
    echo -e "${YELLOW}Security Notes:${NC}"
    echo "• Never commit your token to git"
    echo "• Store it securely (e.g., in ~/.homeassistant_token)"
    echo "• You can revoke it anytime from the profile page"
    echo "• The token gives full access to your Home Assistant"
}

test_token() {
    local token="$1"
    
    echo -e "${BLUE}Testing API token...${NC}"
    
    local api_url="http://$HA_SERVER:$HA_PORT/api/"
    local response
    
    if response=$(curl -s -w "%{http_code}" -H "Authorization: Bearer $token" "$api_url"); then
        local http_code="${response: -3}"
        if [[ "$http_code" == "200" ]]; then
            echo -e "${GREEN}✓ Token is valid and working${NC}"
            return 0
        else
            echo -e "${RED}✗ Token test failed (HTTP $http_code)${NC}"
            return 1
        fi
    else
        echo -e "${RED}✗ Failed to test token${NC}"
        return 1
    fi
}

main() {
    local open_browser_flag=false
    
    # Parse command line arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --open-browser)
                open_browser_flag=true
                shift
                ;;
            --help)
                usage
                exit 0
                ;;
            *)
                echo "Unknown option: $1"
                usage
                exit 1
                ;;
        esac
    done
    
    echo -e "${GREEN}Home Assistant API Token Helper${NC}"
    echo "Server: http://$HA_SERVER:$HA_PORT"
    echo ""
    
    if [[ "$open_browser_flag" == "true" ]]; then
        open_browser
        echo ""
    fi
    
    show_instructions
    
    # Ask if user wants to test a token
    echo -e "${YELLOW}Do you want to test a token? (y/N): ${NC}"
    read -r test_token_choice
    
    if [[ "$test_token_choice" == "y" || "$test_token_choice" == "Y" ]]; then
        echo -e "${YELLOW}Enter your token: ${NC}"
        read -r token
        
        if test_token "$token"; then
            echo ""
            echo -e "${GREEN}Great! Your token is working.${NC}"
            echo "You can now run:"
            echo "export HA_TOKEN=$token"
            echo "./bin/ha-pull-api-v2"
        else
            echo ""
            echo -e "${RED}Token test failed. Please check your token and try again.${NC}"
        fi
    fi
}

main "$@"
