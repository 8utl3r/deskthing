# Copy to .env and fill in values
# Option A: Email + password (script fetches token on demand)
NPM_URL=http://192.168.0.158:30020
# For NPM+ (forces HTTPS): NPM_URL=https://192.168.0.158:30360
NPM_EMAIL=admin@example.com
NPM_PASSWORD=

# Option B: Token only (expires ~24-48h; run: ./npm-api.sh get-token to refresh)
# NPM_TOKEN=
