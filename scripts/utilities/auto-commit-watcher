#!/usr/bin/env bash
# Auto-commit watcher using Cursor CLI for AI-generated commit messages
# Watches for file changes and automatically commits with AI-generated messages

set -euo pipefail

# Configuration
# Load from Cursor settings if available, otherwise use defaults
CURSOR_SETTINGS="$HOME/Library/Application Support/Cursor/User/settings.json"
CONFIG_FILE="$(cd "$(dirname "$0")" && pwd)/auto-commit-watcher-config.json"

# Load configuration
load_config() {
  # Try to read from Cursor settings first
  if [ -f "$CURSOR_SETTINGS" ] && command -v jq > /dev/null 2>&1; then
    WATCH_INTERVAL=$(jq -r '.["autoCommitWatcher.watchInterval"] // 30' "$CURSOR_SETTINGS" 2>/dev/null || echo "30")
    COMMIT_DELAY=$(jq -r '.["autoCommitWatcher.commitDelay"] // 5' "$CURSOR_SETTINGS" 2>/dev/null || echo "5")
    ENABLED=$(jq -r '.["autoCommitWatcher.enabled"] // true' "$CURSOR_SETTINGS" 2>/dev/null | grep -q "true" && echo "1" || echo "0")
    
    # Read watch directories
    if jq -e '.["autoCommitWatcher.watchDirectories"]' "$CURSOR_SETTINGS" > /dev/null 2>&1; then
      WATCH_DIRS=$(jq -r '.["autoCommitWatcher.watchDirectories"] | join(" ")' "$CURSOR_SETTINGS" 2>/dev/null || echo "")
    fi
    
    # Read AI prompt
    if jq -e '.["autoCommitWatcher.aiCommitPrompt"]' "$CURSOR_SETTINGS" > /dev/null 2>&1; then
      AI_PROMPT=$(jq -r '.["autoCommitWatcher.aiCommitPrompt"]' "$CURSOR_SETTINGS" 2>/dev/null || echo "")
    fi
  fi
  
  # Fallback to config file or environment variables
  WATCH_INTERVAL=${WATCH_INTERVAL:-${WATCH_INTERVAL_ENV:-30}}
  COMMIT_DELAY=${COMMIT_DELAY:-${COMMIT_DELAY_ENV:-5}}
  DRY_RUN=${DRY_RUN:-${DRY_RUN_ENV:-0}}
  ENABLED=${ENABLED:-${ENABLED_ENV:-1}}
  WATCH_DIRS=${WATCH_DIRS:-""}
  AI_PROMPT=${AI_PROMPT:-""}
}

LOG_FILE="${LOG_FILE:-$HOME/.auto_commit_watcher.log}"
STATUS_FILE="${STATUS_FILE:-$HOME/.auto_commit_watcher_status.json}"

# Initialize config (call after setting defaults)
load_config

# Paths
REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
CURSOR_BIN="/Applications/Cursor.app/Contents/Resources/app/bin/cursor"
CURSOR_AGENT_BIN="$HOME/.local/bin/cursor-agent"
LOCK_FILE="/tmp/auto_commit_watcher.lock"

# Status tracking
update_status() {
  local status="$1"
  local message="$2"
  local countdown="${3:-}"
  local last_commit="${4:-}"
  
  # Handle empty countdown
  local countdown_json="null"
  if [ -n "$countdown" ] && [ "$countdown" != "null" ]; then
    countdown_json="$countdown"
  fi
  
  # Get last commit time safely
  local last_commit_time="never"
  if cd "$REPO_ROOT" 2>/dev/null; then
    local commit_timestamp=$(git log -1 --format=%ct 2>/dev/null || echo "0")
    if [ "$commit_timestamp" != "0" ] && [ -n "$commit_timestamp" ]; then
      last_commit_time=$(date -r "$commit_timestamp" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo "never")
    fi
  fi
  
  cat > "$STATUS_FILE" <<EOF
{
  "status": "$status",
  "message": "$message",
  "countdown": $countdown_json,
  "lastCommit": "$last_commit",
  "timestamp": $(date +%s),
  "lastCommitTime": "$last_commit_time"
}
EOF
}

# Files/patterns to ignore
IGNORE_PATTERNS=(
  "*.log"
  "*.tmp"
  ".DS_Store"
  "node_modules/"
  ".git/"
  "scripts/state/"
  "*.iso"
  ".auto_commit_watcher.log"
  ".auto_commit_watcher.out.log"
  ".auto_commit_watcher.err.log"
  ".auto_commit_message"
)

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Logging
log() {
  local level="$1"
  shift
  local message="$*"
  local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
  echo "[$timestamp] [$level] $message" | tee -a "$LOG_FILE"
}

log_info() {
  log "INFO" "$@"
}

log_warn() {
  echo -e "${YELLOW}[WARN]${NC} $*" | tee -a "$LOG_FILE"
  log "WARN" "$@"
}

log_error() {
  echo -e "${RED}[ERROR]${NC} $*" | tee -a "$LOG_FILE"
  log "ERROR" "$@"
}

log_success() {
  echo -e "${GREEN}[SUCCESS]${NC} $*" | tee -a "$LOG_FILE"
  log "SUCCESS" "$@"
}

# Check if already running
check_lock() {
  if [ -f "$LOCK_FILE" ]; then
    local pid=$(cat "$LOCK_FILE" 2>/dev/null || echo "")
    if [ -n "$pid" ] && ps -p "$pid" > /dev/null 2>&1; then
      log_error "Another instance is already running (PID: $pid)"
      exit 1
    else
      rm -f "$LOCK_FILE"
    fi
  fi
  echo $$ > "$LOCK_FILE"
}

# Cleanup on exit
cleanup() {
  rm -f "$LOCK_FILE"
  log_info "Watcher stopped"
  exit 0
}

trap cleanup EXIT INT TERM

# Check if Cursor CLI is available (no longer needed, but kept for compatibility)
check_cursor() {
  # No longer using Cursor CLI - commit messages come from AUTO_COMMIT comments
  log_info "Using AUTO_COMMIT message extraction (no CLI required)"
  return 0
}

# Check if file should be ignored
should_ignore() {
  local file="$1"
  local basename_file
  basename_file=$(basename "$file")
  
  for pattern in "${IGNORE_PATTERNS[@]}"; do
    # Handle glob patterns (e.g., *.log, *.tmp, *.iso)
    case "$pattern" in
      *.log|*.tmp|*.iso)
        # Extract extension from pattern (remove *)
        local ext="${pattern#*.}"
        case "$file" in
          *".$ext")
            return 0  # Should ignore
            ;;
        esac
        ;;
      */)
        # Directory pattern (e.g., node_modules/)
        case "$file" in
          *"$pattern"*)
            return 0  # Should ignore
            ;;
        esac
        ;;
      *)
        # Simple substring or exact match
        case "$file" in
          *"$pattern"*)
            return 0  # Should ignore
            ;;
        esac
        case "$basename_file" in
          "$pattern")
            return 0  # Should ignore
            ;;
        esac
        ;;
    esac
  done
  return 1  # Should not ignore
}

# Get changed files (excluding ignored and outside watch directories)
get_changed_files() {
  cd "$REPO_ROOT"
  git status --porcelain | while read -r status file; do
    # Check if file should be ignored
    if should_ignore "$file"; then
      continue
    fi
    
    # If watch directories are specified, only include files in those directories
    if [ -n "$WATCH_DIRS" ]; then
      local in_watch_dir=0
      for dir in $WATCH_DIRS; do
        if [[ "$file" == "$dir"/* ]] || [[ "$file" == "$dir" ]]; then
          in_watch_dir=1
          break
        fi
      done
      if [ "$in_watch_dir" -eq 0 ]; then
        continue
      fi
    fi
    
    echo "$file"
  done
}

# Extract commit message from AUTO_COMMIT comments or file
extract_commit_message() {
  local changed_files="$1"
  local commit_msg=""
  
  cd "$REPO_ROOT"
  
  # Method 1: Check for .auto_commit_message file (highest priority)
  if [ -f ".auto_commit_message" ]; then
    commit_msg=$(head -1 .auto_commit_message | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    if [ -n "$commit_msg" ] && [ "${#commit_msg}" -ge 5 ]; then
      log_info "Found commit message in .auto_commit_message: $commit_msg"
      echo "$commit_msg"
      return 0
    fi
  fi
  
  # Method 2: Look for AUTO_COMMIT comments in changed files
  # Check each changed file for AUTO_COMMIT comments
  while IFS= read -r file; do
    if [ -z "$file" ] || [ ! -f "$file" ]; then
      continue
    fi
    
    # Check for shell/script comments: # AUTO_COMMIT: message
    commit_msg=$(grep -h "^[[:space:]]*# AUTO_COMMIT:" "$file" 2>/dev/null | head -1 | sed 's/^[[:space:]]*# AUTO_COMMIT:[[:space:]]*//' | sed 's/[[:space:]]*$//')
    if [ -n "$commit_msg" ]; then
      log_info "Found commit message in $file: $commit_msg"
      echo "$commit_msg"
      return 0
    fi
    
    # Check for HTML/XML comments: <!-- AUTO_COMMIT: message -->
    commit_msg=$(grep -h "<!--[[:space:]]*AUTO_COMMIT:" "$file" 2>/dev/null | head -1 | sed 's/.*<!--[[:space:]]*AUTO_COMMIT:[[:space:]]*//' | sed 's/[[:space:]]*-->.*//' | sed 's/[[:space:]]*$//')
    if [ -n "$commit_msg" ]; then
      log_info "Found commit message in $file: $commit_msg"
      echo "$commit_msg"
      return 0
    fi
    
    # Check for other comment styles: // AUTO_COMMIT: message
    commit_msg=$(grep -h "^[[:space:]]*// AUTO_COMMIT:" "$file" 2>/dev/null | head -1 | sed 's/^[[:space:]]*\/\/ AUTO_COMMIT:[[:space:]]*//' | sed 's/[[:space:]]*$//')
    if [ -n "$commit_msg" ]; then
      log_info "Found commit message in $file: $commit_msg"
      echo "$commit_msg"
      return 0
    fi
  done <<< "$changed_files"
  
  # If no message found, return failure
  return 1
}

# Generate commit message (simple - just extract from comments/file or use fallback)
generate_commit_message() {
  local changed_files="$1"
  
  if [ -z "$changed_files" ]; then
    echo "chore: update files"
    return
  fi
  
  # Try to extract from AUTO_COMMIT comments or file
  local commit_msg
  if commit_msg=$(extract_commit_message "$changed_files"); then
    if [ -n "$commit_msg" ] && [ "${#commit_msg}" -ge 5 ]; then
      echo "$commit_msg"
      return 0
    fi
  fi
  
  # Fallback to heuristic-based message
  log_info "No AUTO_COMMIT message found, using fallback generator"
  commit_msg=$(generate_fallback_message "$changed_files")
  echo "$commit_msg"
}

# Fallback commit message generator
generate_fallback_message() {
  local files="$1"
  local file_count=$(echo "$files" | wc -l | tr -d ' ')
  local first_file=$(echo "$files" | head -1 | sed 's|.*/||')
  
  # Simple heuristic-based message
  if echo "$files" | grep -q "\.md$"; then
    echo "docs: update documentation"
  elif echo "$files" | grep -q "\.json$\|\.toml$\|\.yaml$\|\.yml$"; then
    echo "config: update configuration"
  elif echo "$files" | grep -q "\.sh$\|\.lua$\|\.py$\|\.js$"; then
    echo "refactor: update scripts"
  else
    echo "chore: update $file_count file(s)"
  fi
}

# Commit changes
commit_changes() {
  local commit_msg="$1"
  
  cd "$REPO_ROOT"
  
  # Stage all changes
  log_info "Staging all changes..."
  git add -A
  
  # Check if there are actually changes to commit
  if git diff --cached --quiet; then
    log_info "No changes staged for commit"
    return 1
  fi
  
  local staged_count
  staged_count=$(git diff --cached --name-only | wc -l | tr -d ' ')
  log_info "Staged $staged_count file(s) for commit"
  
  if [ "$DRY_RUN" -eq 1 ]; then
    log_info "DRY RUN: Would commit with message: $commit_msg"
    git reset  # Unstage for dry run
    return 0
  fi
  
  # Commit
  log_info "Creating commit..."
  if git commit -m "$commit_msg" 2>&1; then
    log_success "Committed: $commit_msg"
    return 0
  else
    log_error "Failed to commit (check git status)"
    return 1
  fi
}

# Push changes
push_changes() {
  if [ "$DRY_RUN" -eq 1 ]; then
    log_info "DRY RUN: Would push to origin/main"
    return 0
  fi
  
  cd "$REPO_ROOT"
  
  log_info "Pushing to origin/main..."
  local push_output
  if push_output=$(git push origin main 2>&1); then
    log_success "Pushed to origin/main"
    return 0
  else
    log_warn "Failed to push: $push_output"
    log_warn "May need to pull first or check remote connection"
    return 1
  fi
}

# Main watch loop
watch_loop() {
  local last_change_time=0
  local pending_commit=0
  
  log_info "Starting auto-commit watcher"
  log_info "Watch interval: ${WATCH_INTERVAL}s, Commit delay: ${COMMIT_DELAY}s"
  log_info "Repository: $REPO_ROOT"
  if [ -n "$WATCH_DIRS" ]; then
    log_info "Watching directories: $WATCH_DIRS"
  else
    log_info "Watching all directories"
  fi
  
  # Initialize status
  update_status "idle" "Watching for changes" "" ""
  
  if [ "$DRY_RUN" -eq 1 ]; then
    log_warn "DRY RUN MODE - No actual commits will be made"
  fi
  
  while true; do
    # Check if enabled
    if [ "$ENABLED" -eq 0 ]; then
      sleep "$WATCH_INTERVAL"
      continue
    fi
    
    # Get changed files
    local changed_files
    changed_files=$(get_changed_files)
    
    if [ -n "$changed_files" ]; then
      # List the changed files
      local file_count=$(echo "$changed_files" | wc -l | tr -d ' ')
      log_info "Changes detected ($file_count file(s)):"
      echo "$changed_files" | head -10 | while read -r file; do
        log_info "  - $file"
      done
      if [ "$file_count" -gt 10 ]; then
        log_info "  ... and $((file_count - 10)) more file(s)"
      fi
      
      # New changes detected
      if [ "$pending_commit" -eq 0 ]; then
        last_change_time=$(date +%s)
        pending_commit=1
        log_info "Waiting ${COMMIT_DELAY}s before committing..."
        update_status "waiting" "Changes detected, waiting ${COMMIT_DELAY}s" "$COMMIT_DELAY" ""
      else
        # More changes while waiting - only reset timer if it's been less than half the delay
        # This prevents infinite resets while still allowing new changes to be included
        local now=$(date +%s)
        local time_since_change=$((now - last_change_time))
        local half_delay=$((COMMIT_DELAY / 2))
        
        if [ "$time_since_change" -lt "$half_delay" ]; then
          last_change_time=$(date +%s)
          log_info "Additional changes detected, resetting ${COMMIT_DELAY}s timer..."
          update_status "waiting" "Additional changes detected, resetting timer" "$COMMIT_DELAY" ""
        else
          local remaining=$((COMMIT_DELAY - time_since_change))
          log_info "Additional changes detected, but will commit soon (${time_since_change}s/${COMMIT_DELAY}s)..."
          update_status "waiting" "Will commit soon" "$remaining" ""
        fi
      fi
    else
      # No changes detected
      if [ "$pending_commit" -eq 0 ]; then
        log_info "No changes detected"
        # Update status only occasionally to avoid file I/O spam
        local now=$(date +%s)
        local last_status_time=$(jq -r '.timestamp // 0' "$STATUS_FILE" 2>/dev/null || echo "0")
        if [ $((now - last_status_time)) -ge 60 ]; then
          update_status "idle" "Watching for changes" "" ""
        fi
      fi
    fi
    
    # Commit if we have pending changes and enough time has passed
    if [ "$pending_commit" -eq 1 ]; then
      local now=$(date +%s)
      local time_since_change=$((now - last_change_time))
      
      if [ "$time_since_change" -ge "$COMMIT_DELAY" ]; then
        # Get fresh list of changed files for commit
        changed_files=$(get_changed_files)
        
        if [ -z "$changed_files" ]; then
          log_info "No changes to commit (files may have been ignored or already committed)"
          pending_commit=0
          last_change_time=0
        else
        log_info "Committing changes..."
        log_info "Files to commit: $(echo "$changed_files" | head -5 | tr '\n' ' ')$([ $(echo "$changed_files" | wc -l) -gt 5 ] && echo " ... and more")"
        update_status "committing" "Committing changes..." "0" ""
        
        # Generate commit message (extract from AUTO_COMMIT comments/file or use fallback)
        local commit_msg
        commit_msg=$(generate_commit_message "$changed_files")
        
        if [ -z "$commit_msg" ] || [ "${#commit_msg}" -lt 5 ]; then
          commit_msg=$(generate_fallback_message "$changed_files")
          log_warn "No AUTO_COMMIT message found, using fallback: $commit_msg"
        else
          log_info "Using commit message: $commit_msg"
        fi
          
          # Commit
          if commit_changes "$commit_msg"; then
            # Delete .auto_commit_message file if it was used
            if [ -f "$REPO_ROOT/.auto_commit_message" ]; then
              rm -f "$REPO_ROOT/.auto_commit_message"
              log_info "Removed .auto_commit_message file after commit"
            fi
            
            # Push
            push_changes
            pending_commit=0
            last_change_time=0
            changed_files=""
            
            # Update status with last commit info
            local last_commit_short=$(echo "$commit_msg" | cut -c1-50)
            update_status "idle" "Last commit: $last_commit_short" "" "$commit_msg"
          else
            log_error "Commit failed, will retry on next cycle"
            update_status "error" "Commit failed, will retry" "" ""
          fi
        fi
      fi
    fi
    
    # Sleep at end of loop
    sleep "$WATCH_INTERVAL"
  done
}

# Main
main() {
  check_lock
  
  if [ "$ENABLED" -eq 0 ]; then
    log_info "Auto-commit watcher is disabled (set ENABLED=1 to enable)"
    exit 0
  fi
  
  if ! check_cursor; then
    log_warn "Continuing with fallback commit message generation"
  fi
  
  cd "$REPO_ROOT"
  
  if [ ! -d ".git" ]; then
    log_error "Not a git repository: $REPO_ROOT"
    exit 1
  fi
  
  watch_loop
}

# Parse command line arguments
case "${1:-}" in
  --dry-run)
    DRY_RUN=1
    shift
    ;;
  --disable)
    ENABLED=0
    shift
    ;;
  --enable)
    ENABLED=1
    shift
    ;;
  --help|-h)
    cat << EOF
Auto-commit Watcher - Automatically commit and push changes using Cursor CLI

Usage: $0 [OPTIONS]

Options:
  --dry-run    Show what would be committed without actually committing
  --disable    Disable the watcher (ENABLED=0)
  --enable     Enable the watcher (ENABLED=1)
  --help, -h   Show this help message

Environment Variables:
  WATCH_INTERVAL    Seconds between checks (default: 30)
  COMMIT_DELAY      Seconds to wait after last change before committing (default: 5)
  DRY_RUN          Set to 1 for dry-run mode
  ENABLED          Set to 0 to disable, 1 to enable (default: 1)
  LOG_FILE         Path to log file (default: ~/.auto_commit_watcher.log)

Examples:
  $0                    # Start watcher with defaults
  $0 --dry-run          # Test without committing
  WATCH_INTERVAL=60 $0  # Check every 60 seconds
  COMMIT_DELAY=10 $0    # Wait 10 seconds after changes

EOF
    exit 0
    ;;
esac

main "$@"
