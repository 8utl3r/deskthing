#!/usr/bin/env bash
set -euo pipefail
# Manage Cursor (VS Code-compatible) extensions from a tracked list.
# Usage:
#   bin/cursor-extensions install   # install extensions from cursor/extensions.txt
#   bin/cursor-extensions snapshot  # write current extensions to cursor/extensions.txt

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
LIST_FILE="$REPO_ROOT/cursor/extensions.txt"
CLI=""

if command -v cursor >/dev/null 2>&1; then
  CLI="cursor"
elif command -v code >/dev/null 2>&1; then
  CLI="code"
else
  echo "ERROR: Neither 'cursor' nor 'code' CLI found in PATH." >&2
  exit 1
fi

cmd_install() {
  if [[ ! -f "$LIST_FILE" ]]; then
    echo "No extensions list at $LIST_FILE" >&2
    exit 1
  fi
  grep -vE '^(#|\s*$)' "$LIST_FILE" | while read -r ext; do
    echo "Installing $ext"
    "$CLI" --install-extension "$ext" --force || true
  done
}

cmd_snapshot() {
  mkdir -p "$(dirname "$LIST_FILE")"
  "$CLI" --list-extensions > "$LIST_FILE"
  echo "Wrote extensions to $LIST_FILE"
}

case "${1:-}" in
  install) cmd_install ;;
  snapshot) cmd_snapshot ;;
  *) echo "Usage: $0 {install|snapshot}" >&2; exit 2 ;;
 esac
