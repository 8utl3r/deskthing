# Copy to .env and fill in values
# Get API key: Jellyfin Dashboard → Admin → API Keys → + (name: servarr)
JELLYFIN_API_KEY=

# Real-Debrid API key for rdt-client
# Get from: https://real-debrid.com/apitoken
REAL_DEBRID_API_KEY=

# Sabnzbd: API key (Config → General), NZB key (for indexer URLs)
SABNZBD_API_KEY=
SABNZBD_NZB_KEY=

# Usenet indexers (optional) - add to Prowlarr via servarr-pi5-sync-and-usenet-indexers.sh
# Get API keys from each site's Profile page
NZBGEEK_API_KEY=
NZBPLANET_API_KEY=
DRUNKENSLUG_API_KEY=
NINJACENTRAL_API_KEY=

# LazyLibrarian (ebooks/audiobooks) - Config → Interface → Startup
# Full access: for API automation (e.g. config scripts)
# Read only: for limited access if needed
LAZYLIBRARIAN_API_KEY=
LAZYLIBRARIAN_READONLY_API_KEY=
