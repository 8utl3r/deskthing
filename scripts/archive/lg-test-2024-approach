#!/usr/bin/env python3
"""
LG C5 Test - Mimicking lgtv-ip-control Library Approach
Testing the exact protocol used by the working JavaScript library
"""

import socket
import sys
import time
from datetime import datetime
from cryptography.hazmat.primitives.ciphers import Cipher, algorithms, modes
from cryptography.hazmat.backends import default_backend

def log(message, level="INFO"):
    timestamp = datetime.now().strftime("%H:%M:%S.%f")[:-3]
    print(f"[{timestamp}] {level}: {message}")

def log_raw(data, direction):
    """Log raw bytes being sent/received"""
    if isinstance(data, bytes):
        hex_str = data.hex()
        ascii_str = ''.join([chr(b) if 32 <= b <= 126 else f'\\x{b:02x}' for b in data])
        print(f"[RAW {direction}] {hex_str} | {ascii_str}")
    else:
        print(f"[RAW {direction}] {data}")

def pad_command(command_bytes):
    """Pad command to 16-byte boundary for AES encryption"""
    while len(command_bytes) % 16 != 0:
        command_bytes += b'\x00'
    return command_bytes

def encrypt_command(command, keycode):
    """Encrypt command using AES128 ECB (mimicking lgtv-ip-control)"""
    try:
        # Pad keycode to 16 bytes
        key = keycode.encode('utf-8').ljust(16, b'\x00')[:16]
        
        # Pad command to 16-byte boundary
        command_bytes = pad_command(command.encode('utf-8'))
        
        # Encrypt using AES128 ECB
        cipher = Cipher(algorithms.AES(key), modes.ECB(), backend=default_backend())
        encryptor = cipher.encryptor()
        encrypted = encryptor.update(command_bytes) + encryptor.finalize()
        
        return encrypted
    except Exception as e:
        log(f"Encryption failed: {e}", "ERROR")
        return None

def decrypt_response(encrypted_data, keycode):
    """Decrypt response using AES128 ECB"""
    try:
        key = keycode.encode('utf-8').ljust(16, b'\x00')[:16]
        cipher = Cipher(algorithms.AES(key), modes.ECB(), backend=default_backend())
        decryptor = cipher.decryptor()
        decrypted = decryptor.update(encrypted_data) + decryptor.finalize()
        
        # Remove padding
        while decrypted.endswith(b'\x00'):
            decrypted = decrypted[:-1]
        
        return decrypted
    except Exception as e:
        log(f"Decryption failed: {e}", "ERROR")
        return None

def test_lgtv_ip_control_approach(tv_ip, tv_port, command, keycode, mac_address):
    """Test using the exact approach from lgtv-ip-control library"""
    log(f"Testing lgtv-ip-control approach: '{command}'")
    
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(5)
        sock.connect((tv_ip, tv_port))
        log("Connected to TV")
        
        # Test 1: Unencrypted command (as fallback)
        log("Testing unencrypted command...")
        unencrypted_cmd = command.encode('utf-8') + b'\x0D'
        log_raw(unencrypted_cmd, "SEND")
        sock.send(unencrypted_cmd)
        
        sock.settimeout(2)
        try:
            response = sock.recv(1024)
            if response:
                log_raw(response, "RECV")
                log(f"🎉 SUCCESS! Unencrypted response: {response.decode('utf-8', errors='ignore')}")
                sock.close()
                return True
            else:
                log("No unencrypted response")
        except socket.timeout:
            log("Unencrypted response timeout")
        
        # Test 2: Encrypted command (primary method)
        log("Testing encrypted command...")
        encrypted_cmd = encrypt_command(command, keycode)
        if encrypted_cmd:
            log_raw(encrypted_cmd, "SEND")
            sock.send(encrypted_cmd)
            sock.send(b'\x0D')  # Carriage return
            
            sock.settimeout(2)
            try:
                response = sock.recv(1024)
                if response:
                    log_raw(response, "RECV")
                    
                    # Try to decrypt response
                    if response.endswith(b'\x0A'):
                        encrypted_data = response.rstrip(b'\x0A')
                        if encrypted_data:
                            decrypted = decrypt_response(encrypted_data, keycode)
                            if decrypted:
                                log(f"🎉 SUCCESS! Decrypted response: {decrypted.decode('utf-8', errors='ignore')}")
                                sock.close()
                                return True
                    
                    log(f"Raw response: {response.decode('utf-8', errors='ignore')}")
                    sock.close()
                    return True
                else:
                    log("No encrypted response")
            except socket.timeout:
                log("Encrypted response timeout")
        
        sock.close()
        return False
        
    except Exception as e:
        log(f"❌ lgtv-ip-control approach failed: {e}", "ERROR")
        return False

def test_2024_protocol_variations(tv_ip, tv_port, command, keycode):
    """Test various 2024 protocol variations"""
    log(f"Testing 2024 protocol variations for: '{command}'")
    
    # Different command formats that might work for 2024 models
    command_variations = [
        command,  # Original command
        f"{command}\n",  # With newline
        f"{command}\r\n",  # With CRLF
        f"{command}\x00",  # With null terminator
        f"{command}\x0A",  # With line feed
        f"{command}\x0D",  # With carriage return
        f"{command}\x0D\x0A",  # With CRLF
    ]
    
    for i, cmd in enumerate(command_variations):
        log(f"Testing variation {i+1}: '{cmd}'")
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(3)
            sock.connect((tv_ip, tv_port))
            
            cmd_bytes = cmd.encode('utf-8')
            log_raw(cmd_bytes, "SEND")
            sock.send(cmd_bytes)
            
            sock.settimeout(2)
            try:
                response = sock.recv(1024)
                if response:
                    log_raw(response, "RECV")
                    log(f"🎉 SUCCESS! Variation {i+1} worked: {response.decode('utf-8', errors='ignore')}")
                    sock.close()
                    return True
                else:
                    log(f"No response for variation {i+1}")
            except socket.timeout:
                log(f"Timeout for variation {i+1}")
            
            sock.close()
            time.sleep(0.5)
            
        except Exception as e:
            log(f"Variation {i+1} failed: {e}")
    
    return False

def main():
    if len(sys.argv) < 2:
        print("Usage: python3 lg-test-2024-approach <tv_ip> [keycode] [mac_address]")
        sys.exit(1)
    
    tv_ip = sys.argv[1]
    keycode = sys.argv[2] if len(sys.argv) > 2 else "IKXTFKE6"
    mac_address = sys.argv[3] if len(sys.argv) > 3 else "58:96:0a:c3:1g:5b"
    
    log(f"🚀 Testing 2024 approach for {tv_ip}")
    log(f"Keycode: {keycode}, MAC: {mac_address}")
    
    # Test commands that should work with 2024 models
    test_commands = [
        "CURRENT_VOL",
        "POWER ?",
        "VOLUME_MUTE on",
        "KEY_ACTION volumeup",
        "KEY_ACTION volumedown"
    ]
    
    for command in test_commands:
        log(f"\n=== Testing Command: {command} ===")
        
        # Test 1: lgtv-ip-control approach
        if test_lgtv_ip_control_approach(tv_ip, 9761, command, keycode, mac_address):
            log(f"✅ SUCCESS! lgtv-ip-control approach worked for '{command}'")
            return
        
        time.sleep(1)
        
        # Test 2: 2024 protocol variations
        if test_2024_protocol_variations(tv_ip, 9761, command, keycode):
            log(f"✅ SUCCESS! 2024 protocol variation worked for '{command}'")
            return
        
        time.sleep(1)
    
    log("\n❌ All 2024 approaches failed")
    log("The TV still doesn't respond to any network commands")

if __name__ == "__main__":
    main()














