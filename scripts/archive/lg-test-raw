#!/usr/bin/env python3
"""
Simple LG C5 Raw Communication Test
Tests both encrypted and unencrypted communication
"""

import socket
import sys
from datetime import datetime

def log(message, level="INFO"):
    timestamp = datetime.now().strftime("%H:%M:%S.%f")[:-3]
    print(f"[{timestamp}] {level}: {message}")

def log_raw(data, direction):
    """Log raw bytes being sent/received"""
    if isinstance(data, bytes):
        hex_str = data.hex()
        ascii_str = ''.join([chr(b) if 32 <= b <= 126 else f'\\x{b:02x}' for b in data])
        print(f"[RAW {direction}] {hex_str} | {ascii_str}")
    else:
        print(f"[RAW {direction}] {data}")

def test_connection(tv_ip, tv_port=9761):
    """Test raw connection to TV"""
    log(f"Testing connection to {tv_ip}:{tv_port}")
    
    try:
        # Connect
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(5)
        sock.connect((tv_ip, tv_port))
        log("Connected successfully")
        
        # Test 1: Send unencrypted command
        log("=== TEST 1: Unencrypted Command ===")
        command = b"CURRENT_VOL"
        log_raw(command, "SEND")
        sock.send(command)
        sock.send(b'\x0D')  # Carriage return
        
        # Try to receive response
        sock.settimeout(3)
        try:
            response = sock.recv(1024)
            if response:
                log_raw(response, "RECV")
                log(f"Response as text: {response.decode('utf-8', errors='ignore')}")
            else:
                log("No response received")
        except socket.timeout:
            log("Response timeout")
        
        # Test 2: Send encrypted command (simple test)
        log("\n=== TEST 2: Simple Encrypted Command ===")
        encrypted_command = b"CURRENT_VOL"  # For now, just test the same command
        log_raw(encrypted_command, "SEND")
        sock.send(encrypted_command)
        sock.send(b'\x0D')
        
        try:
            response = sock.recv(1024)
            if response:
                log_raw(response, "RECV")
                log(f"Response as text: {response.decode('utf-8', errors='ignore')}")
            else:
                log("No response received")
        except socket.timeout:
            log("Response timeout")
        
        sock.close()
        log("Connection closed")
        
    except Exception as e:
        log(f"Connection failed: {e}", "ERROR")

if __name__ == "__main__":
    if len(sys.argv) != 2:
        print("Usage: python3 lg-test-raw <tv_ip>")
        sys.exit(1)
    
    tv_ip = sys.argv[1]
    test_connection(tv_ip)














