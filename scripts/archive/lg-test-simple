#!/usr/bin/env python3
"""
LG C5 Simple Test - Try different approaches
"""

import socket
import sys
from datetime import datetime

def log(message, level="INFO"):
    timestamp = datetime.now().strftime("%H:%M:%S.%f")[:-3]
    print(f"[{timestamp}] {level}: {message}")

def log_raw(data, direction):
    """Log raw bytes being sent/received"""
    if isinstance(data, bytes):
        hex_str = data.hex()
        ascii_str = ''.join([chr(b) if 32 <= b <= 126 else f'\\x{b:02x}' for b in data])
        print(f"[RAW {direction}] {hex_str} | {ascii_str}")
    else:
        print(f"[RAW {direction}] {data}")

def test_simple_commands(tv_ip, tv_port=9761):
    """Test various simple approaches"""
    log(f"Testing simple commands to {tv_ip}:{tv_port}")
    
    commands_to_try = [
        # Plain text commands
        ("Plain CURRENT_VOL", b"CURRENT_VOL"),
        ("Plain POWER ?", b"POWER ?"),
        ("Plain VOLUME_MUTE on", b"VOLUME_MUTE on"),
        
        # Commands with different postfixes
        ("CURRENT_VOL + \\n", b"CURRENT_VOL\n"),
        ("CURRENT_VOL + \\r\\n", b"CURRENT_VOL\r\n"),
        
        # Try sending just the postfix first
        ("Just \\r", b"\r"),
        ("Just \\n", b"\n"),
        ("Just \\r\\n", b"\r\n"),
    ]
    
    for test_name, command in commands_to_try:
        log(f"\n=== {test_name} ===")
        
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(3)
            sock.connect((tv_ip, tv_port))
            log("Connected")
            
            log_raw(command, "SEND")
            sock.send(command)
            
            # Try to receive any response
            sock.settimeout(2)
            try:
                response = sock.recv(1024)
                if response:
                    log_raw(response, "RECV")
                    log(f"Response text: {response.decode('utf-8', errors='ignore')}")
                else:
                    log("No response")
            except socket.timeout:
                log("Response timeout")
            
            sock.close()
            
        except Exception as e:
            log(f"Test failed: {e}", "ERROR")

if __name__ == "__main__":
    if len(sys.argv) != 2:
        print("Usage: python3 lg-test-simple <tv_ip>")
        sys.exit(1)
    
    tv_ip = sys.argv[1]
    test_simple_commands(tv_ip)














