#!/usr/bin/env python3
"""
LG C5 Test with Set ID + Encryption
Testing encrypted commands with Set ID = 2
"""

import socket
import sys
import time
from datetime import datetime
from cryptography.hazmat.primitives.ciphers import Cipher, algorithms, modes
from cryptography.hazmat.backends import default_backend

def log(message, level="INFO"):
    timestamp = datetime.now().strftime("%H:%M:%S.%f")[:-3]
    print(f"[{timestamp}] {level}: {message}")

def log_raw(data, direction):
    """Log raw bytes being sent/received"""
    if isinstance(data, bytes):
        hex_str = data.hex()
        ascii_str = ''.join([chr(b) if 32 <= b <= 126 else f'\\x{b:02x}' for b in data])
        print(f"[RAW {direction}] {hex_str} | {ascii_str}")
    else:
        print(f"[RAW {direction}] {data}")

def encrypt_command_with_set_id(command, keycode, set_id=2):
    """Encrypt command with Set ID included"""
    try:
        # Pad keycode to 16 bytes
        key = keycode.encode('utf-8').ljust(16, b'\x00')[:16]
        
        # Try different ways to include Set ID in the command
        set_id_str = str(set_id)
        set_id_hex = bytes([set_id])
        
        # Different command formats with Set ID
        command_variations = [
            # Format 1: Command + Set ID as string
            f"{command}{set_id_str}",
            # Format 2: Set ID as string + Command  
            f"{set_id_str}{command}",
            # Format 3: Command + Space + Set ID
            f"{command} {set_id_str}",
            # Format 4: Set ID + Space + Command
            f"{set_id_str} {command}",
            # Format 5: Just the command (maybe Set ID is handled differently)
            command,
        ]
        
        encrypted_commands = []
        for cmd in command_variations:
            # Pad command to 16-byte boundary
            command_bytes = cmd.encode('utf-8')
            while len(command_bytes) % 16 != 0:
                command_bytes += b'\x00'
            
            # Encrypt using AES128 ECB
            cipher = Cipher(algorithms.AES(key), modes.ECB(), backend=default_backend())
            encryptor = cipher.encryptor()
            encrypted = encryptor.update(command_bytes) + encryptor.finalize()
            
            encrypted_commands.append((cmd, encrypted))
        
        return encrypted_commands
        
    except Exception as e:
        log(f"Encryption failed: {e}", "ERROR")
        return []

def test_encrypted_command_with_set_id(tv_ip, tv_port, command, keycode, set_id=2):
    """Test encrypted command with Set ID"""
    log(f"Testing encrypted command '{command}' with Set ID {set_id}")
    
    encrypted_commands = encrypt_command_with_set_id(command, keycode, set_id)
    
    for i, (original_cmd, encrypted_cmd) in enumerate(encrypted_commands):
        log(f"\n--- Encrypted Format {i+1}: '{original_cmd}' ---")
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(3)
            sock.connect((tv_ip, tv_port))
            log("Connected")
            
            log_raw(encrypted_cmd, "SEND")
            sock.send(encrypted_cmd)
            sock.send(b'\x0D')  # Carriage return
            
            # Wait for response
            sock.settimeout(2)
            try:
                response = sock.recv(1024)
                if response:
                    log_raw(response, "RECV")
                    log(f"🎉 SUCCESS! Response: {response.decode('utf-8', errors='ignore')}")
                    sock.close()
                    return True
                else:
                    log("No response")
            except socket.timeout:
                log("Response timeout")
            
            sock.close()
            time.sleep(0.5)
            
        except Exception as e:
            log(f"Encrypted format {i+1} failed: {e}", "ERROR")
    
    return False

def test_lg_c5_encrypted_with_set_id(tv_ip, tv_port=9761, keycode="IKXTFKE6", set_id=2):
    """Test LG C5 with encrypted commands and Set ID"""
    log(f"Testing LG C5 at {tv_ip}:{tv_port} with encrypted commands and Set ID {set_id}")
    
    # Test commands
    test_commands = [
        "CURRENT_VOL",
        "POWER ?",
        "VOLUME_MUTE on",
        "KEY_ACTION volumeup",
        "KEY_ACTION volumedown"
    ]
    
    for command in test_commands:
        if test_encrypted_command_with_set_id(tv_ip, tv_port, command, keycode, set_id):
            log(f"✅ SUCCESS! Encrypted command '{command}' worked with Set ID {set_id}")
            return True
        time.sleep(1)
    
    log("❌ No encrypted commands worked with Set ID")
    return False

def main():
    if len(sys.argv) < 2:
        print("Usage: python3 lg-test-encrypted-set-id <tv_ip> [keycode] [set_id]")
        sys.exit(1)
    
    tv_ip = sys.argv[1]
    keycode = sys.argv[2] if len(sys.argv) > 2 else "IKXTFKE6"
    set_id = int(sys.argv[3]) if len(sys.argv) > 3 else 2
    
    success = test_lg_c5_encrypted_with_set_id(tv_ip, keycode=keycode, set_id=set_id)
    if success:
        print(f"\n🎉 SUCCESS! Encrypted commands with Set ID {set_id} worked!")
    else:
        print(f"\n❌ Still no response with encrypted commands and Set ID {set_id}")

if __name__ == "__main__":
    main()














