def test_webos_http_approach(tv_ip, tv_port=3000):
    """Test webOS API using HTTP approach"""
    log(f"Testing webOS API HTTP approach on {tv_ip}:{tv_port}")
    
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(5)
        sock.connect((tv_ip, tv_port))
        log("✅ Connected to webOS API")
        
        # Test HTTP GET request
        http_request = f"GET / HTTP/1.1\r\nHost: {tv_ip}\r\n\r\n"
        log(f"Sending HTTP request: {http_request.strip()}")
        log_raw(http_request.encode('utf-8'), "SEND")
        sock.send(http_request.encode('utf-8'))
        
        # Wait for response
        sock.settimeout(3)
        try:
            response = sock.recv(1024)
            if response:
                log_raw(response, "RECV")
                log(f"📥 HTTP Response: {response.decode('utf-8', errors='ignore')}")
                sock.close()
                return True
            else:
                log("No HTTP response")
        except socket.timeout:
            log("HTTP response timeout")
        
        sock.close()
        return False
        
    except Exception as e:
        log(f"❌ webOS HTTP test failed: {e}", "ERROR")
        return False

def main():
    if len(sys.argv) < 2:
        print("Usage: python3 lg-test-webos-comprehensive <tv_ip> [port]")
        sys.exit(1)
    
    tv_ip = sys.argv[1]
    tv_port = int(sys.argv[2]) if len(sys.argv) > 2 else 3000
    
    log(f"🚀 Comprehensive webOS API test for {tv_ip}:{tv_port}")
    
    # Test 1: Basic webOS API handshake
    log("\n=== TEST 1: Basic webOS API Handshake ===")
    if test_webos_handshake(tv_ip, tv_port):
        log("✅ webOS API handshake successful!")
        return
    
    # Test 2: Try different ports
    for port in [3000, 3001, 8080]:
        if port != tv_port:
            log(f"\nTrying port {port}...")
            if test_webos_handshake(tv_ip, port):
                log(f"✅ webOS API works on port {port}!")
                return
    
    # Test 3: Test pairing process
    log("\n=== TEST 2: webOS API Pairing ===")
    pairing_result = test_webos_pairing(tv_ip, tv_port)
    if pairing_result == "pairing_required":
        log("🔐 Pairing required - check TV screen for pairing prompt")
        log("Accept the pairing request on your TV, then run this test again")
        return
    elif pairing_result:
        log("✅ webOS API pairing successful!")
        return
    
    # Test 4: Test webOS commands
    log("\n=== TEST 3: webOS API Commands ===")
    if test_webos_commands(tv_ip, tv_port):
        log("✅ webOS API commands are working!")
        return
    
    # Test 5: Test control commands
    log("\n=== TEST 4: webOS API Control Commands ===")
    if test_webos_control_commands(tv_ip, tv_port):
        log("✅ webOS API control commands are working!")
        return
    
    # Test 6: Test HTTP approach
    log("\n=== TEST 5: webOS API HTTP Approach ===")
    if test_webos_http_approach(tv_ip, tv_port):
        log("✅ webOS API HTTP approach is working!")
        return
    
    log("\n❌ webOS API is not responding")
    log("This suggests the webOS API is disabled or not available")

if __name__ == "__main__":
    main()














