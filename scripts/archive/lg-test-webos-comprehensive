#!/usr/bin/env python3
"""
LG C5 webOS API Comprehensive Test
Test webOS API with various approaches after enabling IP Control
"""

import socket
import sys
import time
import json
from datetime import datetime

def log(message, level="INFO"):
    timestamp = datetime.now().strftime("%H:%M:%S.%f")[:-3]
    print(f"[{timestamp}] {level}: {message}")

def log_raw(data, direction):
    """Log raw bytes being sent/received"""
    if isinstance(data, bytes):
        hex_str = data.hex()
        ascii_str = ''.join([chr(b) if 32 <= b <= 126 else f'\\x{b:02x}' for b in data])
        print(f"[RAW {direction}] {hex_str} | {ascii_str}")
    else:
        print(f"[RAW {direction}] {data}")

def test_webos_handshake(tv_ip, tv_port=3000):
    """Test webOS API handshake and pairing"""
    log(f"Testing webOS API handshake on {tv_ip}:{tv_port}")
    
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(5)
        sock.connect((tv_ip, tv_port))
        log("✅ Connected to webOS API")
        
        # Test 1: Basic webOS API request
        request = {
            "type": "request",
            "id": "test_1",
            "uri": "ssap://system/getSystemInfo"
        }
        
        request_json = json.dumps(request) + "\n"
        log(f"Sending: {request_json.strip()}")
        log_raw(request_json.encode('utf-8'), "SEND")
        sock.send(request_json.encode('utf-8'))
        
        # Wait for response
        sock.settimeout(3)
        try:
            response = sock.recv(1024)
            if response:
                log_raw(response, "RECV")
                log(f"📥 Response: {response.decode('utf-8', errors='ignore')}")
                sock.close()
                return True
            else:
                log("No response to webOS API request")
        except socket.timeout:
            log("webOS API response timeout")
        
        sock.close()
        return False
        
    except Exception as e:
        log(f"❌ webOS API test failed: {e}", "ERROR")
        return False

def test_webos_pairing(tv_ip, tv_port=3000):
    """Test webOS API pairing process"""
    log(f"Testing webOS API pairing on {tv_ip}:{tv_port}")
    
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(5)
        sock.connect((tv_ip, tv_port))
        log("✅ Connected to webOS API")
        
        # Test pairing request
        pairing_request = {
            "type": "request",
            "id": "pairing_1",
            "uri": "ssap://system/getSystemInfo"
        }
        
        request_json = json.dumps(pairing_request) + "\n"
        log(f"Sending pairing request: {request_json.strip()}")
        log_raw(request_json.encode('utf-8'), "SEND")
        sock.send(request_json.encode('utf-8'))
        
        # Wait for response
        sock.settimeout(3)
        try:
            response = sock.recv(1024)
            if response:
                log_raw(response, "RECV")
                response_text = response.decode('utf-8', errors='ignore')
                log(f"📥 Pairing response: {response_text}")
                
                # Check if we need to pair
                if "pairing" in response_text.lower() or "pair" in response_text.lower():
                    log("🔐 Pairing required - check TV screen for pairing prompt")
                    return "pairing_required"
                else:
                    log("✅ Pairing successful or not required")
                    return True
            else:
                log("No response to pairing request")
        except socket.timeout:
            log("Pairing request timeout")
        
        sock.close()
        return False
        
    except Exception as e:
        log(f"❌ webOS pairing test failed: {e}", "ERROR")
        return False

