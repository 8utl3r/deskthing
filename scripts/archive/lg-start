#!/bin/bash
# LG C5 Control Server Startup Script
# Starts the persistent server and debug monitor

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SERVER_SCRIPT="$SCRIPT_DIR/lg-server"
DEBUG_SCRIPT="$SCRIPT_DIR/lg-debug"
STATUS_FILE="/tmp/lg-server-status.json"
LOG_FILE="/tmp/lg-server.log"

LG_IP="${1:-192.168.0.39}"

echo "📺 LG C5 Control Server Startup"
echo "================================"
echo "IP Address: $LG_IP"
echo "Server Script: $SERVER_SCRIPT"
echo "Debug Script: $DEBUG_SCRIPT"
echo "Status File: $STATUS_FILE"
echo "Log File: $LOG_FILE"
echo

# Check if server is already running
if pgrep -f "lg-server" > /dev/null; then
    echo "⚠️  LG server is already running"
    echo "Use 'lg-debug monitor' to view status"
    echo "Use 'pkill -f lg-server' to stop"
    exit 1
fi

# Test connection first
echo "🔍 Testing connection to $LG_IP:9761..."
if ! nc -z -w5 "$LG_IP" 9761; then
    echo "❌ Cannot connect to $LG_IP:9761"
    echo "Make sure:"
    echo "  - TV is powered on"
    echo "  - Network IP Control is enabled"
    echo "  - IP address is correct"
    echo "  - TV is on the same network"
    exit 1
fi
echo "✅ Connection test successful"

# Start server
echo "🚀 Starting LG server..."
nohup "$SERVER_SCRIPT" "$LG_IP" > "$LOG_FILE" 2>&1 &
SERVER_PID=$!

echo "📊 Server started with PID: $SERVER_PID"
echo "📋 Log file: $LOG_FILE"
echo "📊 Status file: $STATUS_FILE"
echo

# Wait a moment for server to initialize
sleep 2

# Check if server started successfully
if ! kill -0 "$SERVER_PID" 2>/dev/null; then
    echo "❌ Server failed to start"
    echo "Check log file: $LOG_FILE"
    exit 1
fi

echo "✅ Server started successfully!"
echo
echo "🎮 Available commands:"
echo "  lg-debug monitor     - Real-time status monitoring"
echo "  lg-debug status      - Show current status"
echo "  lg-debug log         - Show recent log entries"
echo "  lg-debug interactive - Interactive command mode"
echo "  lg-debug test --ip $LG_IP - Test connection"
echo
echo "🖥️  Hammerspoon integration:"
echo "  - Menu bar item shows real-time status"
echo "  - Click for command menu"
echo "  - Hotkeys: ⌘⌥⌃P (power), ⌘⌥⌃↑/↓ (volume), ⌘⌥⌃M (mute)"
echo "  - Hotkeys: ⌘⌥⌃1-4 (HDMI inputs), ⌘⌥⌃T (test), ⌘⌥⌃D (debug)"
echo
echo "🛑 To stop server: pkill -f lg-server"
echo "📊 To monitor: lg-debug monitor"















