#!/usr/bin/env python3
"""
LG C5 Test - Based on Working lgtv-ip-control Library Approach
Testing both encrypted and non-encrypted modes
"""

import socket
import sys
import time
from datetime import datetime
from cryptography.hazmat.primitives.ciphers import Cipher, algorithms, modes
from cryptography.hazmat.backends import default_backend

def log(message, level="INFO"):
    timestamp = datetime.now().strftime("%H:%M:%S.%f")[:-3]
    print(f"[{timestamp}] {level}: {message}")

def log_raw(data, direction):
    """Log raw bytes being sent/received"""
    if isinstance(data, bytes):
        hex_str = data.hex()
        ascii_str = ''.join([chr(b) if 32 <= b <= 126 else f'\\x{b:02x}' for b in data])
        print(f"[RAW {direction}] {hex_str} | {ascii_str}")
    else:
        print(f"[RAW {direction}] {data}")

def encrypt_command_simple(command, keycode):
    """Simple encryption approach based on working library"""
    try:
        # Pad keycode to 16 bytes
        key = keycode.encode('utf-8').ljust(16, b'\x00')[:16]
        
        # Simple padding - just pad to 16-byte boundary
        command_bytes = command.encode('utf-8')
        while len(command_bytes) % 16 != 0:
            command_bytes += b'\x00'
        
        # Encrypt using AES128 ECB
        cipher = Cipher(algorithms.AES(key), modes.ECB(), backend=default_backend())
        encryptor = cipher.encryptor()
        encrypted = encryptor.update(command_bytes) + encryptor.finalize()
        
        return encrypted
        
    except Exception as e:
        log(f"Encryption failed: {e}", "ERROR")
        return command.encode('utf-8')

def test_command(tv_ip, tv_port, command, keycode=None, encrypted=False):
    """Test a single command"""
    log(f"Testing command: {command} (encrypted: {encrypted})")
    
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(5)
        sock.connect((tv_ip, tv_port))
        log("Connected")
        
        if encrypted and keycode:
            # Send encrypted command
            encrypted_command = encrypt_command_simple(command, keycode)
            log_raw(encrypted_command, "SEND")
            sock.send(encrypted_command)
            sock.send(b'\x0D')  # Carriage return
        else:
            # Send unencrypted command
            command_bytes = command.encode('utf-8')
            log_raw(command_bytes, "SEND")
            sock.send(command_bytes)
            sock.send(b'\x0D')  # Carriage return
        
        # Wait for response
        sock.settimeout(3)
        try:
            response = sock.recv(1024)
            if response:
                log_raw(response, "RECV")
                log(f"🎉 SUCCESS! TV responded: {response.decode('utf-8', errors='ignore')}")
                return True
            else:
                log("No response")
                return False
        except socket.timeout:
            log("Response timeout")
            return False
        
        sock.close()
        
    except Exception as e:
        log(f"Command failed: {e}", "ERROR")
        return False

def test_lg_c5(tv_ip, tv_port=9761, keycode="IKXTFKE6"):
    """Test LG C5 with both encrypted and non-encrypted approaches"""
    log(f"Testing LG C5 at {tv_ip}:{tv_port} with keycode {keycode}")
    
    # Test commands to try
    test_commands = [
        "CURRENT_VOL",
        "POWER ?",
        "VOLUME_MUTE on",
        "KEY_ACTION volumeup",
        "KEY_ACTION volumedown"
    ]
    
    log("\n=== Testing NON-ENCRYPTED Commands ===")
    unencrypted_success = False
    for command in test_commands:
        if test_command(tv_ip, tv_port, command, encrypted=False):
            unencrypted_success = True
            break
        time.sleep(0.5)  # Small delay between commands
    
    if unencrypted_success:
        log("✅ NON-ENCRYPTED commands are working!")
        return True
    
    log("\n=== Testing ENCRYPTED Commands ===")
    encrypted_success = False
    for command in test_commands:
        if test_command(tv_ip, tv_port, command, keycode=keycode, encrypted=True):
            encrypted_success = True
            break
        time.sleep(0.5)  # Small delay between commands
    
    if encrypted_success:
        log("✅ ENCRYPTED commands are working!")
        return True
    
    log("❌ Neither encrypted nor unencrypted commands are working")
    return False

if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Usage: python3 lg-test-working-approach <tv_ip> [keycode]")
        sys.exit(1)
    
    tv_ip = sys.argv[1]
    keycode = sys.argv[2] if len(sys.argv) > 2 else "IKXTFKE6"
    
    success = test_lg_c5(tv_ip, keycode=keycode)
    if success:
        print("\n🎉 SUCCESS! Found working approach!")
    else:
        print("\n❌ No working approach found")














