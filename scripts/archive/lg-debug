#!/usr/bin/env python3
"""
LG C5 Debug Monitor
Real-time monitoring of server status and TV communication

Features:
- Live status display
- Command log tailing
- Manual command sending
- Connection testing
- State history tracking
"""

import json
import time
import os
import sys
import argparse
from datetime import datetime
from typing import Dict, Any, Optional
import threading
import subprocess

class LGDebugMonitor:
    def __init__(self, status_file: str = "/tmp/lg-server-status.json", 
                 log_file: str = "/tmp/lg-server.log"):
        self.status_file = status_file
        self.log_file = log_file
        self.running = False
        self.last_status = {}
        self.command_history = []
        
    def clear_screen(self):
        """Clear terminal screen"""
        os.system('clear' if os.name == 'posix' else 'cls')
        
    def get_status(self) -> Optional[Dict[str, Any]]:
        """Read current server status"""
        try:
            if os.path.exists(self.status_file):
                with open(self.status_file, 'r') as f:
                    return json.load(f)
        except Exception as e:
            print(f"Error reading status: {e}")
        return None
        
    def tail_log(self, lines: int = 20) -> list:
        """Get last N lines from log file"""
        try:
            if os.path.exists(self.log_file):
                with open(self.log_file, 'r') as f:
                    all_lines = f.readlines()
                    return all_lines[-lines:] if len(all_lines) > lines else all_lines
        except Exception as e:
            print(f"Error reading log: {e}")
        return []
        
    def display_status(self):
        """Display current status"""
        status = self.get_status()
        if not status:
            print("❌ No server status available")
            return
            
        state = status.get('state', {})
        
        print("📺 LG C5 Control Server Status")
        print("=" * 50)
        
        # Connection status
        conn_status = state.get('connection_status', 'UNKNOWN')
        if conn_status == 'CONNECTED':
            print(f"🔗 Connection: ✅ {conn_status}")
        elif conn_status == 'DISCONNECTED':
            print(f"🔗 Connection: ❌ {conn_status}")
        else:
            print(f"🔗 Connection: ⚠️  {conn_status}")
            
        # TV State
        print(f"🔌 Power: {state.get('power', 'UNKNOWN')}")
        print(f"🔊 Volume: {state.get('volume', 'UNKNOWN')}")
        print(f"🔇 Mute: {state.get('mute', 'UNKNOWN')}")
        print(f"📺 Input: {state.get('input_source', 'UNKNOWN')}")
        
        # Last activity
        print(f"⏰ Last Update: {state.get('last_update', 'Never')}")
        print(f"📤 Last Command: {state.get('last_command', 'None')}")
        print(f"📥 Last Response: {state.get('last_response', 'None')}")
        
        # Server info
        print(f"🖥️  Server Running: {'✅ Yes' if status.get('server_running') else '❌ No'}")
        print(f"📊 Queue Size: {status.get('queue_size', 0)}")
        
        print()
        
    def display_log(self, lines: int = 10):
        """Display recent log entries"""
        log_lines = self.tail_log(lines)
        if log_lines:
            print("📋 Recent Log Entries")
            print("-" * 50)
            for line in log_lines[-lines:]:
                print(line.rstrip())
        else:
            print("📋 No log entries available")
        print()
        
    def send_command(self, command: str):
        """Send command to server via status file"""
        try:
            # Create command file for server to pick up
            cmd_file = "/tmp/lg-server-command.json"
            cmd_data = {
                "command": command,
                "timestamp": datetime.now().isoformat(),
                "source": "debug_monitor"
            }
            
            with open(cmd_file, 'w') as f:
                json.dump(cmd_data, f)
                
            print(f"📤 Sent command: {command}")
            
        except Exception as e:
            print(f"❌ Failed to send command: {e}")
            
    def interactive_mode(self):
        """Interactive command mode"""
        print("🎮 Interactive Command Mode")
        print("Commands: power_on, power_off, volume_up, volume_down, mute, query_volume")
        print("Type 'quit' to exit")
        print()
        
        while True:
            try:
                cmd = input("lg> ").strip()
                if cmd.lower() in ['quit', 'exit', 'q']:
                    break
                elif cmd:
                    self.send_command(cmd)
                    time.sleep(0.5)  # Give server time to process
                    
            except KeyboardInterrupt:
                break
            except EOFError:
                break
                
    def monitor_mode(self):
        """Continuous monitoring mode"""
        self.running = True
        print("🔄 Starting continuous monitoring (Ctrl+C to stop)")
        
        try:
            while self.running:
                self.clear_screen()
                self.display_status()
                self.display_log(8)
                
                print("Press Ctrl+C to stop monitoring")
                time.sleep(2)
                
        except KeyboardInterrupt:
            self.running = False
            print("\n🛑 Monitoring stopped")
            
    def test_connection(self, ip: str, port: int = 9761):
        """Test direct connection to TV"""
        print(f"🔍 Testing connection to {ip}:{port}")
        
        try:
            import socket
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(5)
            
            start_time = time.time()
            result = sock.connect_ex((ip, port))
            connect_time = time.time() - start_time
            
            if result == 0:
                print(f"✅ Connection successful ({connect_time:.2f}s)")
                
                # Try sending a test command
                test_cmd = "CURRENT_VOL"
                sock.send(test_cmd.encode() + b'\x0D')
                
                try:
                    sock.settimeout(2)
                    response = sock.recv(1024)
                    if response:
                        print(f"📥 Response: {response.decode('utf-8', errors='ignore')}")
                    else:
                        print("📥 No response received")
                except socket.timeout:
                    print("⏰ Response timeout")
                    
            else:
                print(f"❌ Connection failed (code: {result})")
                
            sock.close()
            
        except Exception as e:
            print(f"❌ Connection test error: {e}")
            
    def show_help(self):
        """Show help information"""
        print("LG C5 Debug Monitor Help")
        print("=" * 30)
        print("Commands:")
        print("  monitor    - Continuous status monitoring")
        print("  status     - Show current status once")
        print("  log        - Show recent log entries")
        print("  interactive - Interactive command mode")
        print("  test <ip>  - Test connection to TV")
        print("  help       - Show this help")
        print()
        print("Available TV Commands:")
        print("  power_on, power_off, volume_up, volume_down")
        print("  mute, unmute, input_hdmi1, input_hdmi2, input_hdmi3, input_hdmi4")
        print("  query_volume, query_power, query_input")
        print()

def main():
    parser = argparse.ArgumentParser(description="LG C5 Debug Monitor")
    parser.add_argument("command", nargs="?", default="monitor", 
                       help="Command to run (monitor, status, log, interactive, test, help)")
    parser.add_argument("--ip", help="TV IP address for connection test")
    parser.add_argument("--port", type=int, default=9761, help="TV port for connection test")
    parser.add_argument("--status-file", default="/tmp/lg-server-status.json", help="Status file path")
    parser.add_argument("--log-file", default="/tmp/lg-server.log", help="Log file path")
    
    args = parser.parse_args()
    
    monitor = LGDebugMonitor(args.status_file, args.log_file)
    
    if args.command == "monitor":
        monitor.monitor_mode()
    elif args.command == "status":
        monitor.display_status()
    elif args.command == "log":
        monitor.display_log(20)
    elif args.command == "interactive":
        monitor.interactive_mode()
    elif args.command == "test":
        if args.ip:
            monitor.test_connection(args.ip, args.port)
        else:
            print("❌ IP address required for connection test")
            print("Usage: lg-debug test --ip 192.168.0.39")
    elif args.command == "help":
        monitor.show_help()
    else:
        print(f"❌ Unknown command: {args.command}")
        monitor.show_help()

if __name__ == "__main__":
    main()















