#!/usr/bin/env python3
"""
LG C5 Comprehensive Test - Try everything
"""

import socket
import sys
from datetime import datetime

def log(message, level="INFO"):
    timestamp = datetime.now().strftime("%H:%M:%S.%f")[:-3]
    print(f"[{timestamp}] {level}: {message}")

def log_raw(data, direction):
    """Log raw bytes being sent/received"""
    if isinstance(data, bytes):
        hex_str = data.hex()
        ascii_str = ''.join([chr(b) if 32 <= b <= 126 else f'\\x{b:02x}' for b in data])
        print(f"[RAW {direction}] {hex_str} | {ascii_str}")
    else:
        print(f"[RAW {direction}] {data}")

def test_comprehensive(tv_ip, tv_port=9761, keycode="IKXTFKE6"):
    """Test comprehensive set of commands and approaches"""
    log(f"Comprehensive test to {tv_ip}:{tv_port} with keycode {keycode}")
    
    # Test different command approaches
    test_commands = [
        # Basic commands without encryption
        ("Basic CURRENT_VOL", b"CURRENT_VOL\r"),
        ("Basic POWER ?", b"POWER ?\r"),
        ("Basic VOLUME_MUTE on", b"VOLUME_MUTE on\r"),
        
        # Commands with different postfixes
        ("CURRENT_VOL + \\n", b"CURRENT_VOL\n"),
        ("CURRENT_VOL + \\r\\n", b"CURRENT_VOL\r\n"),
        
        # Try sending keycode as command
        ("Send keycode", keycode.encode() + b"\r"),
        
        # Try different power states
        ("POWER on", b"POWER on\r"),
        ("POWER off", b"POWER off\r"),
        
        # Try volume commands
        ("VOLUME_MUTE off", b"VOLUME_MUTE off\r"),
        ("KEY_ACTION volumeup", b"KEY_ACTION volumeup\r"),
        ("KEY_ACTION volumedown", b"KEY_ACTION volumedown\r"),
        
        # Try input commands
        ("APP_LAUNCH com.webos.app.hdmi1", b"APP_LAUNCH com.webos.app.hdmi1\r"),
    ]
    
    for test_name, command in test_commands:
        log(f"\n=== {test_name} ===")
        
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(3)
            sock.connect((tv_ip, tv_port))
            log("Connected")
            
            log_raw(command, "SEND")
            sock.send(command)
            
            # Wait for response
            sock.settimeout(2)
            try:
                response = sock.recv(1024)
                if response:
                    log_raw(response, "RECV")
                    log(f"Response text: {response.decode('utf-8', errors='ignore')}")
                    log("🎉 SUCCESS! TV responded!")
                    break
                else:
                    log("No response")
            except socket.timeout:
                log("Response timeout")
            
            sock.close()
            
        except Exception as e:
            log(f"Test failed: {e}", "ERROR")

if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Usage: python3 lg-test-comprehensive <tv_ip> [keycode]")
        sys.exit(1)
    
    tv_ip = sys.argv[1]
    keycode = sys.argv[2] if len(sys.argv) > 2 else "IKXTFKE6"
    
    test_comprehensive(tv_ip, keycode=keycode)














