#!/usr/bin/env python3
"""
LG C5 Test with Set ID - This might be the missing piece!
Testing commands with Set ID = 2
"""

import socket
import sys
import time
from datetime import datetime

def log(message, level="INFO"):
    timestamp = datetime.now().strftime("%H:%M:%S.%f")[:-3]
    print(f"[{timestamp}] {level}: {message}")

def log_raw(data, direction):
    """Log raw bytes being sent/received"""
    if isinstance(data, bytes):
        hex_str = data.hex()
        ascii_str = ''.join([chr(b) if 32 <= b <= 126 else f'\\x{b:02x}' for b in data])
        print(f"[RAW {direction}] {hex_str} | {ascii_str}")
    else:
        print(f"[RAW {direction}] {data}")

def create_command_with_set_id(command, set_id=2):
    """Create command with Set ID in proper format"""
    # Set ID 2 in hex is 0x02
    set_id_hex = bytes([set_id])
    
    # Command format: [Command] [Set ID] [Data] [Cr]
    # For LG TVs, the format might be different, let's try variations
    
    command_bytes = command.encode('utf-8')
    
    # Try different formats
    formats = [
        # Format 1: Command + Set ID + CR
        command_bytes + set_id_hex + b'\x0D',
        # Format 2: Set ID + Command + CR  
        set_id_hex + command_bytes + b'\x0D',
        # Format 3: Command + Space + Set ID + CR
        command_bytes + b' ' + set_id_hex + b'\x0D',
        # Format 4: Set ID + Space + Command + CR
        set_id_hex + b' ' + command_bytes + b'\x0D',
        # Format 5: Command + Set ID as string + CR
        command_bytes + str(set_id).encode() + b'\x0D',
        # Format 6: Set ID as string + Command + CR
        str(set_id).encode() + command_bytes + b'\x0D',
    ]
    
    return formats

def test_command_with_set_id(tv_ip, tv_port, command, set_id=2):
    """Test a command with Set ID included"""
    log(f"Testing command '{command}' with Set ID {set_id}")
    
    command_formats = create_command_with_set_id(command, set_id)
    
    for i, command_bytes in enumerate(command_formats):
        log(f"\n--- Format {i+1} ---")
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(3)
            sock.connect((tv_ip, tv_port))
            log("Connected")
            
            log_raw(command_bytes, "SEND")
            sock.send(command_bytes)
            
            # Wait for response
            sock.settimeout(2)
            try:
                response = sock.recv(1024)
                if response:
                    log_raw(response, "RECV")
                    log(f"🎉 SUCCESS! Response: {response.decode('utf-8', errors='ignore')}")
                    sock.close()
                    return True
                else:
                    log("No response")
            except socket.timeout:
                log("Response timeout")
            
            sock.close()
            time.sleep(0.5)
            
        except Exception as e:
            log(f"Format {i+1} failed: {e}", "ERROR")
    
    return False

def test_lg_c5_with_set_id(tv_ip, tv_port=9761, set_id=2):
    """Test LG C5 with Set ID included"""
    log(f"Testing LG C5 at {tv_ip}:{tv_port} with Set ID {set_id}")
    
    # Test commands
    test_commands = [
        "CURRENT_VOL",
        "POWER ?",
        "VOLUME_MUTE on",
        "KEY_ACTION volumeup",
        "KEY_ACTION volumedown"
    ]
    
    for command in test_commands:
        if test_command_with_set_id(tv_ip, tv_port, command, set_id):
            log(f"✅ SUCCESS! Command '{command}' worked with Set ID {set_id}")
            return True
        time.sleep(1)
    
    log("❌ No commands worked with Set ID")
    return False

def main():
    if len(sys.argv) < 2:
        print("Usage: python3 lg-test-set-id <tv_ip> [set_id]")
        sys.exit(1)
    
    tv_ip = sys.argv[1]
    set_id = int(sys.argv[2]) if len(sys.argv) > 2 else 2
    
    success = test_lg_c5_with_set_id(tv_ip, set_id=set_id)
    if success:
        print(f"\n🎉 SUCCESS! Set ID {set_id} was the missing piece!")
    else:
        print(f"\n❌ Still no response with Set ID {set_id}")

if __name__ == "__main__":
    main()














