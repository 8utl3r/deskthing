#!/usr/bin/env python3
"""
LG C5 Comprehensive Port Scan
Test all possible ports and protocols to see if the TV responds to anything
"""

import socket
import sys
import time
from datetime import datetime

def log(message, level="INFO"):
    timestamp = datetime.now().strftime("%H:%M:%S.%f")[:-3]
    print(f"[{timestamp}] {level}: {message}")

def test_port(tv_ip, port, timeout=2):
    """Test if a port is open and responsive"""
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(timeout)
        result = sock.connect_ex((tv_ip, port))
        sock.close()
        return result == 0
    except:
        return False

def test_port_with_data(tv_ip, port, data, timeout=2):
    """Test port with data and see if we get any response"""
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(timeout)
        sock.connect((tv_ip, port))
        
        sock.send(data)
        
        # Try to receive any response
        sock.settimeout(1)
        try:
            response = sock.recv(1024)
            if response:
                log(f"Port {port}: Got response: {response.hex()} | {response.decode('utf-8', errors='ignore')}")
                sock.close()
                return True
        except socket.timeout:
            pass
        
        sock.close()
        return False
    except Exception as e:
        return False

def scan_all_ports(tv_ip):
    """Scan all common ports to see what's open"""
    log(f"Scanning all ports on {tv_ip}...")
    
    # Common ports for TV control
    ports_to_test = [
        3000, 3001, 3002,  # WebOS API
        8080, 8081, 8082,  # HTTP/Alternative
        9761, 9762, 9763,  # Network IP Control
        9999, 9998, 9997,  # Alternative control
        80, 443, 8000, 8001,  # HTTP/HTTPS
        22, 23, 21, 25, 53,  # Common services
        5000, 5001, 5002,  # Alternative
        7000, 7001, 7002,  # Alternative
        9000, 9001, 9002,  # Alternative
    ]
    
    open_ports = []
    responsive_ports = []
    
    for port in ports_to_test:
        if test_port(tv_ip, port, 1):
            open_ports.append(port)
            log(f"✅ Port {port} is open")
            
            # Test with different data formats
            test_data = [
                b"CURRENT_VOL\r\n",
                b"CURRENT_VOL\n",
                b"CURRENT_VOL\r",
                b"CURRENT_VOL",
                b"POWER ?\r\n",
                b"VOLUME_MUTE on\r\n",
                b"GET / HTTP/1.1\r\nHost: " + tv_ip.encode() + b"\r\n\r\n",
                b"POST / HTTP/1.1\r\nHost: " + tv_ip.encode() + b"\r\nContent-Length: 0\r\n\r\n",
            ]
            
            for data in test_data:
                if test_port_with_data(tv_ip, port, data):
                    responsive_ports.append((port, data))
                    break
    
    return open_ports, responsive_ports

def test_udp_ports(tv_ip):
    """Test UDP ports for broadcast/control protocols"""
    log(f"Testing UDP ports on {tv_ip}...")
    
    udp_ports = [9761, 3000, 8080, 9999, 1900, 5353]
    
    for port in udp_ports:
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            sock.settimeout(1)
            
            # Send UDP packet
            data = b"CURRENT_VOL"
            sock.sendto(data, (tv_ip, port))
            
            # Try to receive response
            try:
                response, addr = sock.recvfrom(1024)
                log(f"UDP Port {port}: Got response from {addr}: {response.hex()} | {response.decode('utf-8', errors='ignore')}")
            except socket.timeout:
                pass
            
            sock.close()
        except Exception as e:
            pass

def main():
    if len(sys.argv) < 2:
        print("Usage: python3 lg-test-port-scan <tv_ip>")
        sys.exit(1)
    
    tv_ip = sys.argv[1]
    
    log(f"🔍 Comprehensive port scan for {tv_ip}")
    
    # Test 1: TCP port scan
    open_ports, responsive_ports = scan_all_ports(tv_ip)
    
    log(f"\n📊 Results:")
    log(f"Open ports: {open_ports}")
    log(f"Responsive ports: {responsive_ports}")
    
    # Test 2: UDP port test
    test_udp_ports(tv_ip)
    
    if responsive_ports:
        log(f"\n🎉 Found responsive ports! This suggests the TV can be controlled.")
        for port, data in responsive_ports:
            log(f"Port {port} responds to: {data}")
    else:
        log(f"\n❌ No responsive ports found. The TV may not support network control.")

if __name__ == "__main__":
    main()














