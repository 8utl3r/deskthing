# Windows PC SSH (password auth)
# Copy to .env and fill in your Windows password
#
# WINDOWS_SSH_PASSWORD: Your Windows user password
# WINDOWS_SSH_USER: SSH username (default: pete)
# WINDOWS_SSH_HOST: IP or hostname (default: 192.168.0.47)
#
WINDOWS_SSH_PASSWORD=""
WINDOWS_SSH_USER="pete"
WINDOWS_SSH_HOST="192.168.0.47"
