              {
                "type": "basic",
                "from": { "key_code": "mute" },
                "to": [ { "key_code": "f10" } ]
              },
              {
                "type": "basic",
                "from": { "key_code": "volume_decrement" },
                "to": [ { "key_code": "f11" } ]
              },
              {
                "type": "basic",
                "from": { "key_code": "volume_increment" },
                "to": [ { "key_code": "f12" } ]
              }
            ]
          }
        ]
      }
    }
  ]
