{
  "title": "Windows Keyboard Support",
  "rules": [
    {
      "description": "Windows Keyboard: Map functionless keys to useful actions",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "print_screen"
          },
          "to": [
            {
              "key_code": "f13"
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "scroll_lock"
          },
          "to": [
            {
              "key_code": "f14"
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "pause"
          },
          "to": [
            {
              "key_code": "f15"
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "insert"
          },
          "to": [
            {
              "key_code": "f16"
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "home"
          },
          "to": [
            {
              "key_code": "left_arrow",
              "modifiers": ["left_command"]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "end"
          },
          "to": [
            {
              "key_code": "right_arrow",
              "modifiers": ["left_command"]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "page_up"
          },
          "to": [
            {
              "key_code": "up_arrow",
              "modifiers": ["left_command"]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "page_down"
          },
          "to": [
            {
              "key_code": "down_arrow",
              "modifiers": ["left_command"]
            }
          ]
        }
      ]
    }
  ]
}
