        {
          "type": "basic",
          "from": {
            "key_code": "k",
            "modifiers": {
              "mandatory": ["left_command", "left_control", "left_option", "left_shift"]
            }
          },
          "to": [
            {
              "key_code": "k",
              "modifiers": ["left_command", "left_control", "left_option", "left_shift"]
            }
          ]
